---
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer";
import Loader from "../components/Loader.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
}
const { 
  title, 
  description = "Tanuj Pandey is a professional Full Stack Engineer with 4+ years of experience building secure, performant web products, interactive user interfaces, and scalable backend systems.",
  image = "https://tanujdev.netlify.app/favicon.svg"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Tanuj Pandey, Full Stack Engineer, Portfolio, Software Engineer, React, Node.js, Astro, Web Developer, Next.js" />
    <meta name="author" content="Tanuj Pandey" />
    
    <!-- Open Graph / Social Previews -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tanujdev.netlify.app/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    
    <!-- Twitter Card Previews -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://tanujdev.netlify.app/" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Dynamic Web Analytics -->
    {import.meta.env.PUBLIC_GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`} is:inline></script>
        <script define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }} is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>

  <body>
    <Loader />
    <Sidebar />

    <slot />
    <Footer client:load/>
    <div class="cursor"></div>
    <div class="cursor2"></div>

    <script src="https://unpkg.com/aos@next/dist/aos.js" is:inline></script>
    <script is:inline>
      AOS.init();
    </script>
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@400;500;600;700;900&display=swap");

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  *:focus-visible {
    outline: 2px solid var(--primary-color);
    outline-offset: 4px;
    border-radius: 4px;
  }

  body {
    overflow-x: hidden;
    height: 100%;
    width: 100%;
  }

  /* Custom Premium Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
    height: 8px;
  }
  ::-webkit-scrollbar-track {
    background: var(--bg-deep);
  }
  ::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    border: 2px solid var(--bg-deep);
  }
  ::-webkit-scrollbar-thumb:hover {
    background: var(--primary-color);
  }

  :root {
    --primary-color: #3B82F6;
    --secondary-color: #60A5FA;
    --accent-color: #22D3EE;
    --bg-dark: #0B1120;
    --bg-deep: #050816;
    --text-primary: #F8FAFC;
    --text-muted: #94A3B8;
    --border-color: rgba(255, 255, 255, 0.08);

    /* Headings - Mobile */
    --h1-mobile: 2.25rem;      
    --h2-mobile: 1.75rem;   
    --h3-mobile: 1.5rem;    
    --h4-mobile: 1.25rem;   
    --h5-mobile: 1.125rem;  
    --h6-mobile: 1rem;      

    /* Paragraph - Mobile */
    --p-mobile: 0.95rem;       
    --small-mobile: 0.85rem; 
    --xs-mobile: 0.75rem;   

    /* Desktop Sizes */
    --h1-desktop: 4rem;   
    --h2-desktop: 2.75rem;   
    --h3-desktop: 2rem;     
    --h4-desktop: 1.5rem;   
    --h5-desktop: 1.25rem;  
    --h6-desktop: 1rem;     

    --p-desktop: 1.05rem;  
    --small-desktop: 0.95rem;  
    --xs-desktop: 0.85rem; 

    /* Line Heights */
    --line-height-tight: 1.15;
    --line-height-normal: 1.6;
    --line-height-relaxed: 1.75;
    --line-height-loose: 2;

    /* Letter Spacing */
    --letter-spacing-tight: -0.03em;
    --letter-spacing-normal: 0;
    --letter-spacing-wide: 0.05em;
    --letter-spacing-wider: 0.1em;

    /* Font Weights */
    --fw-light: 300;
    --fw-normal: 400;
    --fw-medium: 500;
    --fw-semibold: 600;
    --fw-bold: 700;
    --fw-black: 900;
  }

  /* Global Typography Reset */
  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    scroll-behavior: smooth;
  }

  body {
    overflow-x: hidden;
    background-color: var(--bg-deep);
    color: var(--text-muted);
    font-family: 'Inter', sans-serif;
    font-size: var(--p-mobile);
    line-height: var(--line-height-normal);
  }

  h1, h2, h3, h4, h5, h6 {
    color: var(--text-primary);
    font-family: 'Space Grotesk', sans-serif;
    font-weight: var(--fw-black);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    text-transform: uppercase;
  }

  h1 { font-size: var(--h1-mobile); }
  h2 { font-size: var(--h2-mobile); }
  h3 { font-size: var(--h3-mobile); }
  h4 { font-size: var(--h4-mobile); }
  h5 { font-size: var(--h5-mobile); }
  h6 { font-size: var(--h6-mobile); }

  p {
    font-size: var(--p-mobile);
    line-height: var(--line-height-relaxed);
    color: var(--text-muted);
  }

  @media (min-width: 1024px) {
    body { font-size: var(--p-desktop); }
    h1 { font-size: var(--h1-desktop); }
    h2 { font-size: var(--h2-desktop); }
    h3 { font-size: var(--h3-desktop); }
    h4 { font-size: var(--h4-desktop); }
    h5 { font-size: var(--h5-desktop); }
    h6 { font-size: var(--h6-desktop); }
    p { font-size: var(--p-desktop); }
  }

  .cursor {
    width: 25px;
    height: 25px;
    border-radius: 100%;
    border: 1px solid var(--primary-color);
    transition: all 150ms ease-out;
    position: fixed;
    pointer-events: none;
    left: 0;
    top: 0;
    transform: translate(-50%, -50%);
    z-index: 9999;
  }

  .cursor2 {
    width: 8px;
    height: 8px;
    border-radius: 100%;
    background-color: var(--primary-color);
    position: fixed;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 9999;
    transition: width 0.3s, height 0.3s, background-color 0.3s;
  }

  .hover {
    background-color: rgba(59, 130, 246, 0.1);
    border-color: var(--primary-color);
    width: 60px;
    height: 60px;
  }

  .cursorinnerhover {
    width: 4px;
    height: 4px;
    background-color: white;
  }

  /* Text Gradients */
  .text-gradient {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 50%, var(--accent-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% auto;
  }

  /* Premium Card (Glassmorphism) */
  .glass-card {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 2rem;
  }

  @media only screen and (max-width: 1024px) {
    .cursor, .cursor2 {
      display: none !important;
    }
  }

 
  @media only screen and (max-width: 768px) {
    body {
      background: var(--bg-deep);
      background-repeat: no-repeat;
      height: 100%;
      animation: none; /* Disable animation on mobile devices */
    }

    /* Add additional mobile styles if needed */

    /* ....Projects Cards */

    /* .....Blog details */

    .blog-content a {
      color: var(--accent-color);
    }

    .blog-content a:hover {
      color: var(--bg2);
      transition: all ease-in 0.5s;
      text-decoration: underline;
    }
  }
</style>

<script>
  import Lenis from 'lenis';
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Initialize Lenis smooth scroll
  const lenis = new Lenis({
    duration: 1.2,
    easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    orientation: 'vertical',
    gestureOrientation: 'vertical',
    smoothWheel: true,
  });

  // Sync ScrollTrigger with Lenis
  lenis.on('scroll', ScrollTrigger.update);

  gsap.ticker.add((time) => {
    lenis.raf(time * 1000);
  });

  gsap.ticker.lagSmoothing(0);

  // Intercept anchor clicks for #contact and /#contact for smooth local scroll
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const link = target.closest('a');
    if (!link) return;

    const href = link.getAttribute('href');
    if (!href) return;

    if (href === '#contact' || (href === '/#contact' && (window.location.pathname === '/' || window.location.pathname === ''))) {
      const contactSection = document.getElementById('contact');
      if (contactSection) {
        e.preventDefault();
        lenis.scrollTo(contactSection, {
          duration: 1.5,
          offset: -50,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t))
        });
      }
    }
  });

  // Handle hash scrolling on page load/navigation
  const checkHashAndScroll = () => {
    if (window.location.hash === '#contact') {
      const contactSection = document.getElementById('contact');
      if (contactSection) {
        setTimeout(() => {
          lenis.scrollTo(contactSection, {
            duration: 1.5,
            offset: -50,
            immediate: false
          });
        }, 400); // Wait for animations to settle
      }
    }
  };

  window.addEventListener('load', checkHashAndScroll);
  document.addEventListener('astro:after-swap', checkHashAndScroll);

  const cursor = document.querySelector(".cursor");
  const cursorinner = document.querySelector(".cursor2");
  const links = document.querySelectorAll("a, button, .group");

  let mouseX = 0;
  let mouseY = 0;

  document.addEventListener("mousemove", (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;

    gsap.to(cursor, {
      x: mouseX,
      y: mouseY,
      duration: 0.5,
      ease: "power2.out"
    });

    gsap.to(cursorinner, {
      x: mouseX,
      y: mouseY,
      duration: 0.1
    });
  });

  document.addEventListener("mousedown", () => {
    gsap.to(cursor, { scale: 0.8, duration: 0.3 });
    gsap.to(cursorinner, { scale: 2, duration: 0.3 });
  });

  document.addEventListener("mouseup", () => {
    gsap.to(cursor, { scale: 1, duration: 0.3 });
    gsap.to(cursorinner, { scale: 1, duration: 0.3 });
  });

  links.forEach((link) => {
    link.addEventListener("mouseenter", () => {
      gsap.to(cursor, { 
        width: 80, 
        height: 80, 
        backgroundColor: "rgba(59, 130, 246, 0.1)",
        borderColor: "rgba(59, 130, 246, 0.5)",
        duration: 0.3 
      });
      gsap.to(cursorinner, { scale: 0.5, opacity: 0, duration: 0.3 });
    });
    
    link.addEventListener("mouseleave", () => {
      gsap.to(cursor, { 
        width: 25, 
        height: 25, 
        backgroundColor: "transparent",
        borderColor: "var(--primary-color)",
        duration: 0.3 
      });
      gsap.to(cursorinner, { scale: 1, opacity: 1, duration: 0.3 });
    });
  });

  // Hide cursor on mobile
  if (window.innerWidth < 1024) {
    if (cursor) (cursor as HTMLElement).style.display = 'none';
    if (cursorinner) (cursorinner as HTMLElement).style.display = 'none';
  }
</script>
