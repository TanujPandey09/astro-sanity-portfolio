---
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer";
import Loader from "../components/Loader.astro";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>

  <body>
    <Loader />
    <Sidebar />

    <slot />
    <Footer client:load/>
    <div class="cursor"></div>
    <div class="cursor2"></div>

    <script src="https://unpkg.com/aos@next/dist/aos.js" is:inline></script>
    <script is:inline>
      AOS.init();
    </script>
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@100..900&display=swap");

  *{
  
   
  }

  body {
    overflow-x: hidden;
    height: 100%;
    width: 100%;
  }

  /* @import url('https://fonts.googleapis.com/css2?family=Inter:slnt,wght@-10..0,100..900&family=Roboto+Slab:wght@100..900&display=swap'); */

  :root {
    --primary-color: #599692;
    --secondary-color: #626c7d;
    --accent-color: #dfe5ec;
    --bg-dark: #11172a;
    --bg-deep: #000105;

    /* Headings - Mobile */
    --h1-mobile: 2rem;      /* 32px */
    --h2-mobile: 1.75rem;   /* 28px */
    --h3-mobile: 1.5rem;    /* 24px */
    --h4-mobile: 1.25rem;   /* 20px */
    --h5-mobile: 1.125rem;  /* 18px */
    --h6-mobile: 1rem;      /* 16px */

    /* Paragraph - Mobile */
    --p-mobile: 1rem;       /* 16px */
    --small-mobile: 0.875rem; /* 14px */
    --xs-mobile: 0.75rem;   /* 12px */

    /* Desktop Sizes */
    --h1-desktop: 3.5rem;   /* 56px */
    --h2-desktop: 2.5rem;   /* 40px */
    --h3-desktop: 2rem;     /* 32px */
    --h4-desktop: 1.5rem;   /* 24px */
    --h5-desktop: 1.25rem;  /* 20px */
    --h6-desktop: 1rem;     /* 16px */

    --p-desktop: 1.125rem;  /* 18px */
    --small-desktop: 1rem;  /* 16px */
    --xs-desktop: 0.875rem; /* 14px */

    /* Line Heights */
    --line-height-tight: 1.2;
    --line-height-normal: 1.5;
    --line-height-relaxed: 1.75;
    --line-height-loose: 2;

    /* Letter Spacing */
    --letter-spacing-tight: -0.02em;
    --letter-spacing-normal: 0;
    --letter-spacing-wide: 0.05em;
    --letter-spacing-wider: 0.1em;

    /* Font Weights */
    --fw-light: 300;
    --fw-normal: 400;
    --fw-medium: 500;
    --fw-semibold: 600;
    --fw-bold: 700;
    --fw-black: 900;

    /* Spacing Scale */
    --space-xs: 0.25rem;    /* 4px */
    --space-sm: 0.5rem;     /* 8px */
    --space-md: 1rem;       /* 16px */
    --space-lg: 1.5rem;     /* 24px */
    --space-xl: 2rem;       /* 32px */
    --space-2xl: 3rem;      /* 48px */
    --space-3xl: 4rem;      /* 64px */
    --space-4xl: 6rem;      /* 96px */
  }

  /* Global Typography Reset */
  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    overflow-x: hidden;
    background-color: var(--bg-deep);
    color: var(--accent-color);
    font-family: 'Roboto Slab', serif;
    font-size: var(--p-mobile);
    line-height: var(--line-height-normal);
  }

  h1, h2, h3, h4, h5, h6 {
    color: white;
    font-weight: var(--fw-black);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    text-transform: uppercase;
  }

  h1 { font-size: var(--h1-mobile); }
  h2 { font-size: var(--h2-mobile); }
  h3 { font-size: var(--h3-mobile); }
  h4 { font-size: var(--h4-mobile); }
  h5 { font-size: var(--h5-mobile); }
  h6 { font-size: var(--h6-mobile); }

  p {
    font-size: var(--p-mobile);
    line-height: var(--line-height-relaxed);
    color: var(--secondary-color);
  }

  @media (min-width: 1024px) {
    body { font-size: var(--p-desktop); }
    h1 { font-size: var(--h1-desktop); }
    h2 { font-size: var(--h2-desktop); }
    h3 { font-size: var(--h3-desktop); }
    h4 { font-size: var(--h4-desktop); }
    h5 { font-size: var(--h5-desktop); }
    h6 { font-size: var(--h6-desktop); }
    p { font-size: var(--p-desktop); }
  }

  .cursor {
    width: 25px;
    height: 25px;
    border-radius: 100%;
    border: 1px solid var(--primary-color);
    transition: all 150ms ease-out;
    position: fixed;
    pointer-events: none;
    left: 0;
    top: 0;
    transform: translate(-50%, -50%);
    z-index: 9999;
  }

  .cursor2 {
    width: 8px;
    height: 8px;
    border-radius: 100%;
    background-color: var(--primary-color);
    position: fixed;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 9999;
    transition: width 0.3s, height 0.3s, background-color 0.3s;
  }

  .hover {
    background-color: rgba(89, 150, 146, 0.1);
    border-color: var(--primary-color);
    width: 60px;
    height: 60px;
  }

  .cursorinnerhover {
    width: 4px;
    height: 4px;
    background-color: white;
  }

  /* Text Gradients */
  .text-gradient {
    background: linear-gradient(135deg, #599692 0%, #626c7d 50%, #dfe5ec 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% auto;
  }

  /* Premium Card (Glassmorphism) */
  .glass-card {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 2rem;
  }

  @media only screen and (max-width: 768px) {
    .cursor, .cursor2 {
      display: none;
    }
  }

 
  @media only screen and (max-width: 768px) {
    body {
      background: linear-gradient(90deg, #131313);
      background-repeat: no-repeat;
      height: 100%;
      animation: none; /* Disable animation on mobile devices */
    }

    /* Add additional mobile styles if needed */

    /* ....Projects Cards */

    /* .....Blog details */

    .blog-content a {
      color: var(--accent-color);
    }

    .blog-content a:hover {
      color: var(--bg2);
      transition: all ease-in 0.5s;
      text-decoration: underline;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  const cursor = document.querySelector(".cursor");
  const cursorinner = document.querySelector(".cursor2");
  const links = document.querySelectorAll("a, button, .group");

  let mouseX = 0;
  let mouseY = 0;

  document.addEventListener("mousemove", (e) => {
    mouseX = e.clientX;
    mouseY = e.clientY;

    gsap.to(cursor, {
      x: mouseX,
      y: mouseY,
      duration: 0.5,
      ease: "power2.out"
    });

    gsap.to(cursorinner, {
      x: mouseX,
      y: mouseY,
      duration: 0.1
    });
  });

  document.addEventListener("mousedown", () => {
    gsap.to(cursor, { scale: 0.8, duration: 0.3 });
    gsap.to(cursorinner, { scale: 2, duration: 0.3 });
  });

  document.addEventListener("mouseup", () => {
    gsap.to(cursor, { scale: 1, duration: 0.3 });
    gsap.to(cursorinner, { scale: 1, duration: 0.3 });
  });

  links.forEach((link) => {
    link.addEventListener("mouseenter", () => {
      gsap.to(cursor, { 
        width: 80, 
        height: 80, 
        backgroundColor: "rgba(89, 150, 146, 0.1)",
        borderColor: "rgba(89, 150, 146, 0.5)",
        duration: 0.3 
      });
      gsap.to(cursorinner, { scale: 0.5, opacity: 0, duration: 0.3 });
    });
    
    link.addEventListener("mouseleave", () => {
      gsap.to(cursor, { 
        width: 25, 
        height: 25, 
        backgroundColor: "transparent",
        borderColor: "var(--primary-color)",
        duration: 0.3 
      });
      gsap.to(cursorinner, { scale: 1, opacity: 1, duration: 0.3 });
    });
  });

  // Hide cursor on mobile
  if (window.innerWidth < 1024) {
    if (cursor) (cursor as HTMLElement).style.display = 'none';
    if (cursorinner) (cursorinner as HTMLElement).style.display = 'none';
  }
</script>
