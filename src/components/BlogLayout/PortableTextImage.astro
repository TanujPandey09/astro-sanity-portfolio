---
import { urlForImage } from '../BlogLayout/urlforImage';

const {asset, alt} = Astro.props.node

const hasAsset = !!asset;
const url = hasAsset ? urlForImage(asset).url() : '';
const webpUrl = hasAsset ? urlForImage(asset).format('png').url() : '';
---

{hasAsset && (
  <picture>
    <source
      srcset={webpUrl}
      type="image/png"
    />
    <img
      class="responsive__img"
      src={url}
      alt={alt || ""}
    />
  </picture>
)}