---
import { useSanityClient, groq } from "astro-sanity";
import ProjectItem from "./ProjectItem.astro";
import BlogItem from "./BlogItem.astro";
import AiChatbot from "./AiChatbot";
import PremiumBackground from "./PremiumBackground.astro";
import Hero from "./Hero.astro";
import Skills from "./Skills.astro";
import Experience from "./Experience.astro";
import Contact from "./Contact.astro";
import SectionHeader from "./SectionHeader.astro";
import ProjectCard from "./ProjectCard.astro";
import Ticker from "./Ticker.astro";

const query = groq`*[_type == "projects"]{...,BackgroundImage{asset->{url}}}`;
const blogquery = groq`*[_type == "blogs"] | order(_createdAt desc) {...,FeatureImage{asset->{url}}}`;

const projectData = await useSanityClient().fetch(query);
const blogData = await useSanityClient().fetch(blogquery);

const achievements = [
  { number: "15+", label: "Solutions Built", color: "#599692" },
  { number: "4+", label: "Years Impact", color: "#626c7d" },
  { number: "25%", label: "UX Performance", color: "#599692" },
  { number: "100%", label: "Satisfaction", color: "#FFFFFF" },
];
---

<div class="relative min-h-screen selection:bg-[#599692]/30">
  <PremiumBackground />

  <div class="container mx-auto px-4 md:px-8 lg:px-12 relative z-10">
    <!-- Hero Experience -->
    <Hero />

    <Ticker />

    <!-- Achievement Grid -->
    <div class="py-12 md:py-24" data-aos="fade-up">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-white/5 border border-white/5 rounded-3xl md:rounded-[2rem] overflow-hidden">
        {achievements.map((achievement, index) => (
          <div class="p-6 md:p-12 bg-[#11172a] text-center group hover:bg-white/[0.02] transition-colors">
            <div 
              class="text-3xl md:text-5xl lg:text-6xl font-black mb-2 md:mb-4 tracking-tighter transition-transform duration-700 group-hover:scale-110"
              style={`color: ${achievement.color}`}
            >
              {achievement.number}
            </div>
            <div class="text-[7px] md:text-[8px] lg:text-[10px] text-[#626c7d] font-black uppercase tracking-[0.3em] md:tracking-[0.4em]">{achievement.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Modular Sections -->
    <Skills />
    
    <Experience />

    <!-- Projects Section -->
    <section id="projects" class="py-16 md:py-32 relative z-10">
      <div class="max-w-7xl mx-auto">
        <SectionHeader 
          title="Portfolio" 
          gradientText="Archive" 
          subtitle="A selection of high-fidelity platforms and architectural explorations."
        />
        
        <!-- Featured Deliveries (Immersive List) -->
        <div class="mt-16 md:mt-24 space-y-0">
          {projectData?.slice(0, 4).map((project, index) => (
            <ProjectItem project={project} index={index} />
          ))}
        </div>
        
        {projectData?.length > 4 && (
          <div class="mt-24 md:mt-48">
            <div class="flex flex-col md:flex-row items-center justify-between mb-12 md:mb-16 px-4 gap-8">
               <div class="space-y-2 text-center md:text-left">
                  <p class="text-[8px] md:text-[10px] font-black text-[#599692] uppercase tracking-[0.4em] md:tracking-[0.5em]">Repository Index</p>
                  <h3 class="text-2xl md:text-3xl font-black text-white uppercase tracking-tighter">Extended Artifacts</h3>
               </div>
               <button 
                 id="expand-repo"
                 class="group flex items-center gap-4 text-[8px] md:text-[10px] font-black uppercase tracking-[0.3em] md:tracking-[0.4em] text-[#626c7d] hover:text-[#599692] transition-colors"
               >
                 Explore Entire Intel
                 <div class="w-10 h-10 rounded-full border border-white/5 flex items-center justify-center group-hover:border-[#599692] transition-all">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" id="repo-icon" class="transition-transform duration-500"><path d="m6 9 6 6 6-6"/></svg>
                 </div>
               </button>
            </div>

            <div id="repo-grid" class="hidden grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
               {projectData?.slice(4).map((project, index) => (
                 <ProjectCard project={project} index={index} />
               ))}
            </div>

            <div class="mt-16 md:mt-32 flex justify-center">
               <a href="/projects" class="group relative px-10 py-5 md:px-12 md:py-6 border border-white/10 rounded-full text-[8px] md:text-[10px] font-black uppercase tracking-[0.4em] md:tracking-[0.5em] text-white overflow-hidden transition-all duration-500 hover:border-[#599692] text-center">
                  <span class="relative z-10">Access Full Registry Archive</span>
                  <div class="absolute inset-0 bg-[#599692] translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
               </a>
            </div>
          </div>
        )}
      </div>
    </section>

    <!-- Blogs Section -->
    <section id="blogs" class="py-16 md:py-32 relative z-10">
      <div class="max-w-7xl mx-auto">
        <SectionHeader 
          title="Journal" 
          gradientText="Insights" 
          subtitle="Decoding complexity through technical narrative and architectural analysis."
        />
        
        <div class="mt-16 md:mt-24">
          {blogData?.slice(0, 4).map((blog, index) => (
            <BlogItem blog={blog} index={index} />
          ))}
        </div>
        
        <div class="mt-12 md:mt-20 flex justify-center md:justify-end">
           <a href="/blogs" class="group flex items-center gap-4 md:gap-6 text-[8px] md:text-[10px] font-black uppercase tracking-[0.4em] md:tracking-[0.5em] text-[#626c7d] hover:text-[#599692] transition-all">
              Explore All Articles
              <div class="w-8 md:w-12 h-[1px] bg-[#626c7d] group-hover:bg-[#599692] group-hover:w-20 md:group-hover:w-24 transition-all duration-700"></div>
           </a>
        </div>
      </div>
    </section>

    <!-- Contact Experience -->
    <Contact />
  </div>
</div>

<AiChatbot client:only="react" />

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Premium Section Transitions
  const sections = document.querySelectorAll('section');
  sections.forEach(section => {
    gsap.from(section, {
      opacity: 0,
      y: 50,
      duration: 1.5,
      ease: "power4.out",
      scrollTrigger: {
        trigger: section,
        start: "top 80%",
        toggleActions: "play none none none"
      }
    });
  });

  // Repository Expansion Logic
  const expandBtn = document.getElementById('expand-repo');
  const repoGrid = document.getElementById('repo-grid');
  const repoIcon = document.getElementById('repo-icon');

  expandBtn?.addEventListener('click', () => {
    repoGrid?.classList.toggle('hidden');
    repoIcon?.classList.toggle('rotate-180');
    
    const isExpanded = !repoGrid?.classList.contains('hidden');
    expandBtn.querySelector('span') && (expandBtn.querySelector('span')!.textContent = isExpanded ? 'Collapse Repository' : 'Explore Entire Intel');
  });
</script>
