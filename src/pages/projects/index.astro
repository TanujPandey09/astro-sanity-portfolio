---
import { useSanityClient, groq } from "astro-sanity";
import Layout from "../../layouts/Layout.astro";

const query = groq`*[_type == "projects"]{
        ...,
        BackgroundImage{
      asset->{
        url
      }
      },
    }`;

const projectData = await useSanityClient().fetch(query);
import ProjectLayouts from "../../components/ProjectsLayout/ProjectLayouts.astro";

---

  <Layout title="Projects | Tanuj Pandey" description="Explore my portfolio of professional web development projects, SaaS builds, and frontend case studies.">
    <ProjectLayouts projectData={projectData} />
  </Layout>
