---
const { aboutData } = Astro.props;
import { PortableText } from "astro-portabletext";
import SectionHeader from "../SectionHeader.astro";
import PremiumBackground from "../PremiumBackground.astro";
---

<div class="relative min-h-screen selection:bg-[#599692]/30 overflow-hidden">
  <PremiumBackground />

  <main class="container mx-auto px-6 py-32 relative z-10">
    <!-- Hero Section -->
    <section class="grid lg:grid-cols-12 gap-20 items-center mb-48">
      <div class="lg:col-span-12 mb-12" data-aos="fade-down">
         <SectionHeader 
           title="Identity" 
           gradientText="Synthesis" 
           subtitle="Decoding the intersection of technical architecture and creative narrative."
         />
      </div>

      <!-- Image Section -->
      <div class="lg:col-span-5 relative group" data-aos="fade-right">
        <div class="absolute -inset-4 bg-gradient-to-tr from-[#599692] to-[#626c7d] rounded-[3rem] opacity-20 blur-3xl group-hover:opacity-40 transition-opacity duration-1000"></div>
        <div class="relative aspect-[4/5] rounded-[3rem] overflow-hidden border border-white/10 p-2 bg-[#11172a]">
          {aboutData?.[0]?.heroImage?.asset?.url ? (
            <img
              src={aboutData[0].heroImage.asset.url}
              alt="Tanuj Pandey"
              class="w-full h-full object-cover rounded-[2.5rem] grayscale hover:grayscale-0 transition-all duration-1000 scale-110 group-hover:scale-100"
            />
          ) : (
             <div class="w-full h-full bg-white/5 animate-pulse rounded-[2.5rem]"></div>
          )}
        </div>
        
        <!-- Abstract Element -->
        <div class="absolute -bottom-12 -right-12 w-48 h-48 bg-[#599692]/10 rounded-full blur-[80px] -z-10 group-hover:bg-[#599692]/20 transition-all"></div>
      </div>

      <!-- Content -->
      <div class="lg:col-span-7 space-y-12" data-aos="fade-left">
        <div class="prose-container relative">
          <div class="absolute -left-12 top-0 bottom-0 w-[1px] bg-gradient-to-b from-[#599692] via-white/10 to-transparent opacity-20"></div>
          <div class="prose prose-xl prose-invert max-w-none">
             <div class="text-white font-black uppercase tracking-tighter mb-8 leading-tight h2-style">
               "{aboutData?.[0]?.aboutName || "Architecting digital success through technical mastery."}"
             </div>
             <div class="prose-content space-y-6">
               <PortableText value={aboutData?.[0]?.description} />
             </div>
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-8 pt-12">
          <div class="space-y-2">
             <p class="text-[10px] font-black text-[#599692] uppercase tracking-[0.4em]">Efficiency</p>
             <p class="text-2xl text-white font-black tabular-nums">98.5%</p>
          </div>
          <div class="space-y-2">
             <p class="text-[10px] font-black text-[#626c7d] uppercase tracking-[0.4em]">Availability</p>
             <p class="text-2xl text-white font-black tabular-nums">24/7</p>
          </div>
          <div class="space-y-2">
             <p class="text-[10px] font-black text-[#626c7d] uppercase tracking-[0.4em]">Latency</p>
             <p class="text-2xl text-white font-black tabular-nums">&lt;2ms</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Grid (Awwwards Style) -->
    <section class="py-32">
       <div class="grid md:grid-cols-3 gap-px bg-white/5 border border-white/5 rounded-[3rem] overflow-hidden">
          {[
            { title: "Frontend Architecture", desc: "Crafting high-fidelity, high-performance interfaces with modern frameworks and robust state management." },
            { title: "Creative direction", desc: "Synthesizing visual aesthetics with functional requirements to create immersive digital experiences." },
            { title: "Technical Strategy", desc: "Architecting scalable digital ecosystems that align with business objectives and growth trajectory." }
          ].map((service, i) => (
            <div class="group p-16 bg-[#11172a] hover:bg-white/[0.02] transition-colors relative">
               <div class="text-[10px] font-black text-[#599692] mb-8 opacity-40">0{i + 1}</div>
               <h3 class="text-2xl font-black text-white uppercase tracking-tighter mb-6 group-hover:text-gradient transition-all">{service.title}</h3>
               <p class="text-[#626c7d] italic leading-relaxed">"{service.desc}"</p>
               <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-[#599692] scale-x-0 group-hover:scale-x-100 transition-transform duration-700 origin-left"></div>
            </div>
          ))}
       </div>
    </section>
  </main>
</div>

<style>
  .h2-style {
    font-size: clamp(var(--h2-mobile), 5vw, var(--h2-desktop));
  }
  .prose-content {
    color: var(--secondary-color);
    font-size: var(--p-mobile);
    line-height: var(--line-height-relaxed);
    font-style: italic;
  }
  @media (min-width: 1024px) {
    .prose-content {
      font-size: var(--p-desktop);
    }
  }
  .prose p {
    margin-bottom: var(--space-xl);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initAbout = () => {
    gsap.from('.prose-container', {
      opacity: 0,
      x: 50,
      duration: 1.5,
      ease: "power4.out",
      scrollTrigger: {
        trigger: '.prose-container',
        start: "top 80%"
      }
    });
  };

  initAbout();
</script>