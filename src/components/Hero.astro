---
---

<section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden pt-24 pb-16 md:pt-32">
  <!-- Animated Linear Gradient Background -->
  <div class="absolute inset-0 bg-[linear-gradient(45deg,#050816,#0B1120,#0b182d,#050816)] bg-[length:400%_400%] animate-[gradient-bg_15s_ease_infinite] z-0"></div>
  <!-- Subtle Background Grid Overlay -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_80%_80%_at_50%_50%,#000_60%,transparent_100%)] pointer-events-none z-0"></div>

  <div class="container mx-auto px-4 md:px-8 relative z-20">
    <div class="max-w-6xl mx-auto">
      
      <div class="text-center flex flex-col items-center">
        <!-- Badge -->
        <div class="mb-8 flex flex-col sm:flex-row items-center justify-center gap-4" data-aos="fade-up">
           <a href="#contact" class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-[#0B1120] border border-[#3B82F6]/30 hover:border-[#3B82F6] transition-all duration-500 cursor-pointer shadow-[0_0_20px_rgba(59,130,246,0.1)] hover:shadow-[0_0_30px_rgba(59,130,246,0.3)] group relative overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-r from-[#3B82F6]/0 via-[#3B82F6]/10 to-[#3B82F6]/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000"></div>
              <div class="relative w-2 h-2">
                 <div class="absolute inset-0 rounded-full bg-[#22D3EE] animate-ping opacity-75"></div>
                 <div class="relative w-2 h-2 rounded-full bg-[#22D3EE] shadow-[0_0_10px_#22D3EE]"></div>
              </div>
              <span class="text-[9px] font-black uppercase tracking-[0.3em] text-white group-hover:text-[#22D3EE] transition-colors">Available for Projects</span>
           </a>
           <div class="hidden sm:block w-6 h-[1px] bg-white/10"></div>
           <span class="text-[9px] font-black uppercase tracking-[0.4em] text-[#94A3B8]">Full Stack Engineer / AI SaaS Architect</span>
        </div>

        <!-- Headline -->
        <div class="relative mb-8 max-w-5xl" data-aos="fade-up" data-aos-delay="200">
          <h1 class="hero-title font-black text-white leading-[1.05] tracking-tighter uppercase relative z-10 m-0">
            Building Intelligent <br class="hidden md:inline"/>
            <span class="text-gradient">Digital Products</span> <br class="hidden md:inline"/>
            For Modern Businesses.
          </h1>
        </div>

        <!-- Subheadline -->
        <div class="max-w-3xl mb-12 mx-auto" data-aos="fade-up" data-aos-delay="300">
          <p class="text-base md:text-lg text-[#94A3B8] leading-relaxed font-normal text-center">
            Full Stack Engineer specializing in AI-powered SaaS platforms, enterprise systems, and scalable product architecture.
          </p>
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-6 items-center justify-center mb-16" data-aos="fade-up" data-aos-delay="400">
          <button 
            id="resume-btn"
            class="group relative px-10 py-5 bg-white text-black font-black uppercase text-[10px] tracking-[0.4em] overflow-hidden rounded-full transition-all duration-500 hover:scale-105 shadow-[0_0_30px_rgba(255,255,255,0.05)] hover:shadow-[0_0_40px_rgba(59,130,246,0.3)]"
          >
             <span class="relative z-10 group-hover:text-white transition-colors duration-500">Download Resume</span>
             <div class="absolute inset-0 bg-[#3B82F6] translate-y-full group-hover:translate-y-0 transition-transform duration-500 -z-0"></div>
          </button>

          <a href="#contact" class="group flex items-center gap-4 text-white font-black uppercase text-[10px] tracking-[0.4em] transition-all">
             <span class="group-hover:text-[#3B82F6] transition-colors duration-300">Get In Touch</span>
             <div class="h-[1px] w-8 bg-white/20 group-hover:w-16 group-hover:bg-[#3B82F6] transition-all duration-500 shadow-[0_0_10px_rgba(255,255,255,0)] group-hover:shadow-[0_0_15px_#3B82F6]"></div>
          </a>
        </div>

        <!-- Stats Grid -->
        <div class="w-full max-w-4xl grid grid-cols-2 md:grid-cols-4 gap-px bg-white/5 border border-white/5 rounded-2xl overflow-hidden mt-6" data-aos="fade-up" data-aos-delay="500">
          <div class="p-6 md:p-8 bg-[#0B1120]/40 backdrop-blur-md text-center hover:bg-white/[0.01] transition-all group border-b md:border-b-0 border-r border-white/5">
             <div class="text-3xl md:text-4xl font-black text-white mb-1 tracking-tight group-hover:text-[#3B82F6] transition-colors font-mono">4+</div>
             <div class="text-[8px] font-black uppercase tracking-[0.2em] text-[#94A3B8]">Years Experience</div>
          </div>
          <div class="p-6 md:p-8 bg-[#0B1120]/40 backdrop-blur-md text-center hover:bg-white/[0.01] transition-all group border-b md:border-b-0 md:border-r border-white/5">
             <div class="text-3xl md:text-4xl font-black text-white mb-1 tracking-tight group-hover:text-[#22D3EE] transition-colors font-mono">4+</div>
             <div class="text-[8px] font-black uppercase tracking-[0.2em] text-[#94A3B8]">AI Models Integrated</div>
          </div>
          <div class="p-6 md:p-8 bg-[#0B1120]/40 backdrop-blur-md text-center hover:bg-white/[0.01] transition-all group border-r border-white/5">
             <div class="text-3xl md:text-4xl font-black text-white mb-1 tracking-tight group-hover:text-[#3B82F6] transition-colors font-mono">10+</div>
             <div class="text-[8px] font-black uppercase tracking-[0.2em] text-[#94A3B8]">Enterprise Modules</div>
          </div>
          <div class="p-6 md:p-8 bg-[#0B1120]/40 backdrop-blur-md text-center hover:bg-white/[0.01] transition-all group">
             <div class="text-3xl md:text-4xl font-black text-white mb-1 tracking-tight group-hover:text-[#22D3EE] transition-colors font-mono">Multiple</div>
             <div class="text-[8px] font-black uppercase tracking-[0.2em] text-[#94A3B8]">SaaS Products Built</div>
          </div>
        </div>

      </div>

    </div>
  </div>
  
  <!-- Section Divider -->
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-[#050816] to-transparent z-30"></div>
</section>

<style>
  .hero-title {
    font-size: clamp(2.25rem, 6.5vw, 4.5rem);
    text-wrap: balance;
  }

  .text-gradient {
    background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 50%, var(--accent-color) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% auto;
    animation: gradient-flow 5s linear infinite;
  }

  @keyframes gradient-flow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes gradient-bg {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener('portfolio-loaded', () => {
    const tl = gsap.timeline();
    
    tl.from('.hero-title', {
      y: 60,
      opacity: 0,
      duration: 1.5,
      ease: "expo.out"
    })
    .from('#hero p', {
      y: 20,
      opacity: 0,
      duration: 1,
      ease: "power3.out"
    }, "-=1")
    .from('#resume-btn', {
      scale: 0.9,
      opacity: 0,
      duration: 0.8,
      ease: "back.out(1.7)"
    }, "-=0.6");
  });

  // Hero Parallax Scroll animations
  gsap.to('#hero .hero-title', {
    y: 100,
    ease: "none",
    scrollTrigger: {
      trigger: '#hero',
      start: "top top",
      end: "bottom top",
      scrub: true
    }
  });

  gsap.to('#hero p', {
    y: 50,
    ease: "none",
    scrollTrigger: {
      trigger: '#hero',
      start: "top top",
      end: "bottom top",
      scrub: true
    }
  });

  const btn = document.querySelector('#resume-btn');
  btn?.addEventListener('click', () => {
    const link = document.createElement("a");
    link.href = "/Resume.pdf";
    link.target = "_blank";
    link.download = "resume.pdf";
    link.click();
  });
</script>
