---
import { useSanityClient, groq } from "astro-sanity";
import ProjectItem from "./ProjectItem.astro";
import BlogItem from "./BlogItem.astro";
import AiChatbot from "./AiChatbot";
import PremiumBackground from "./PremiumBackground.astro";
import Hero from "./Hero.astro";
import Skills from "./Skills.astro";
import Experience from "./Experience.astro";
import Contact from "./Contact.astro";
import SectionHeader from "./SectionHeader.astro";

const query = groq`*[_type == "projects"]{...,BackgroundImage{asset->{url}}}`;
const blogquery = groq`*[_type == "blogs"] | order(_createdAt desc) {...,FeatureImage{asset->{url}}}`;

const projectData = await useSanityClient().fetch(query);
const blogData = await useSanityClient().fetch(blogquery);

const achievements = [
  { number: "15+", label: "Solutions Built", color: "#599692" },
  { number: "4+", label: "Years Impact", color: "#626c7d" },
  { number: "25%", label: "UX Performance", color: "#599692" },
  { number: "100%", label: "Satisfaction", color: "#FFFFFF" },
];
---

<div class="relative min-h-screen selection:bg-[#599692]/30">
  <PremiumBackground />

  <div class="container mx-auto px-4 md:px-8 lg:px-12 relative z-10">
    <!-- Hero Experience -->
    <Hero />

    <!-- Achievement Grid -->
    <div class="py-24" data-aos="fade-up">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-px bg-white/5 border border-white/5 rounded-[2rem] overflow-hidden">
        {achievements.map((achievement, index) => (
          <div class="p-12 bg-[#11172a] text-center group hover:bg-white/[0.02] transition-colors">
            <div 
              class="text-5xl md:text-6xl font-black mb-4 tracking-tighter transition-transform duration-700 group-hover:scale-110"
              style={`color: ${achievement.color}`}
            >
              {achievement.number}
            </div>
            <div class="text-[10px] text-[#626c7d] font-black uppercase tracking-[0.4em]">{achievement.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Modular Sections -->
    <Skills />
    
    <Experience />

    <!-- Projects Section -->
    <section id="projects" class="py-32 relative z-10">
      <div class="max-w-7xl mx-auto">
        <SectionHeader 
          title="Portfolio" 
          gradientText="Archive" 
          subtitle="A selection of high-fidelity platforms and architectural explorations."
        />
        
        <div class="mt-24 space-y-0">
          {projectData?.map((project, index) => (
            <ProjectItem project={project} index={index} />
          ))}
        </div>
        
        <div class="mt-32 flex justify-center">
           <a href="/projects" class="group relative px-12 py-6 border border-white/10 rounded-full text-[10px] font-black uppercase tracking-[0.5em] text-white overflow-hidden transition-all duration-500 hover:border-[#599692]">
              <span class="relative z-10">View Entire Archive</span>
              <div class="absolute inset-0 bg-[#599692] translate-y-full group-hover:translate-y-0 transition-transform duration-500"></div>
           </a>
        </div>
      </div>
    </section>

    <!-- Blogs Section -->
    <section id="blogs" class="py-32 relative z-10">
      <div class="max-w-7xl mx-auto">
        <SectionHeader 
          title="Journal" 
          gradientText="Insights" 
          subtitle="Decoding complexity through technical narrative and architectural analysis."
        />
        
        <div class="mt-24">
          {blogData?.slice(0, 4).map((blog, index) => (
            <BlogItem blog={blog} index={index} />
          ))}
        </div>
        
        <div class="mt-20 flex justify-end">
           <a href="/blogs" class="group flex items-center gap-6 text-[10px] font-black uppercase tracking-[0.5em] text-[#626c7d] hover:text-[#599692] transition-colors">
              Explore All Articles
              <div class="w-12 h-[1px] bg-[#626c7d] group-hover:bg-[#599692] group-hover:w-24 transition-all duration-700"></div>
           </a>
        </div>
      </div>
    </section>

    <!-- Contact Experience -->
    <Contact />
  </div>
</div>

<AiChatbot client:only="react" />

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Premium Section Transitions
  const sections = document.querySelectorAll('section');
  sections.forEach(section => {
    gsap.from(section, {
      opacity: 0,
      y: 50,
      duration: 1.5,
      ease: "power4.out",
      scrollTrigger: {
        trigger: section,
        start: "top 80%",
        toggleActions: "play none none none"
      }
    });
  });
</script>
