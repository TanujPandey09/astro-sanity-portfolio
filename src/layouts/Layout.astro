---
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    
    <link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>

  <body>
    
    <Sidebar />

    <slot />
    <Footer client:load/>
    <div class="cursor"></div>
    <div class="cursor2"></div>

    <script src="https://unpkg.com/aos@next/dist/aos.js" is:inline></script>
    <script is:inline>
      AOS.init();
    </script>
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@100..900&display=swap");

  *{
  
   
  }

  body{
    overflow-x: hidden;
    background-color: rgba(4, 6, 21, 0.9);
  
  background-size: center;
  height: 100%;
  width: 100%;
  }

  /* @import url('https://fonts.googleapis.com/css2?family=Inter:slnt,wght@-10..0,100..900&family=Roboto+Slab:wght@100..900&display=swap'); */

  :root {
    --primary-color: #599692;
    --secondary-color: #626c7d;
    --accent-color: #dfe5ec;
    --bg-dark: #11172a;
    --bg-deep: #000105;
  }

  body {
    overflow-x: hidden;
    background-color: var(--bg-deep);
    color: var(--accent-color);
  }

  .cursor {
    width: 25px;
    height: 25px;
    border-radius: 100%;
    border: 1px solid var(--primary-color);
    transition: all 150ms ease-out;
    position: fixed;
    pointer-events: none;
    left: 0;
    top: 0;
    transform: translate(-50%, -50%);
    z-index: 9999;
  }

  .cursor2 {
    width: 8px;
    height: 8px;
    border-radius: 100%;
    background-color: var(--primary-color);
    position: fixed;
    transform: translate(-50%, -50%);
    pointer-events: none;
    z-index: 9999;
    transition: width 0.3s, height 0.3s, background-color 0.3s;
  }

  .hover {
    background-color: rgba(89, 150, 146, 0.1);
    border-color: var(--primary-color);
    width: 60px;
    height: 60px;
  }

  .cursorinnerhover {
    width: 4px;
    height: 4px;
    background-color: white;
  }

  /* Text Gradients */
  .text-gradient {
    background: linear-gradient(135deg, #599692 0%, #626c7d 50%, #dfe5ec 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% auto;
  }

  /* Premium Card (Glassmorphism) */
  .glass-card {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 2rem;
  }

  @media only screen and (max-width: 768px) {
    .cursor, .cursor2 {
      display: none;
    }
  }

  .blog-details-content strong {
    font-size: 22px;
    line-height: 36px;
    margin: 40px 0px;
  }

  .blog-details-content li {
    font-size: 16px;
    line-height: 24px;
    padding: 5px 0px;
  }

  .blog-details-content p:nth-of-type(7) {
    background-color: #ced6de;
}

 
  @media only screen and (max-width: 768px) {
    body {
      background: linear-gradient(90deg, #131313);
      background-repeat: no-repeat;
      height: 100%;
      animation: none; /* Disable animation on mobile devices */
    }

    /* Add additional mobile styles if needed */

    /* ....Projects Cards */

    /* .....Blog details */

    .blog-content a {
      color: var(--accent-color);
    }

    .blog-content a:hover {
      color: var(--bg2);
      transition: all ease-in 0.5s;
      text-decoration: underline;
    }
  }
</style>

<script>
  var cursor = document.querySelector(".cursor");
  var cursorinner = document.querySelector(".cursor2");
  var a = document.querySelectorAll("a");

  document.addEventListener("mousemove", function (e) {
    var x = e.clientX;
    var y = e.clientY;
    cursor.style.transform = `translate3d(calc(${e.clientX}px - 50%), calc(${e.clientY}px - 50%), 0)`;
  });

  document.addEventListener("mousemove", function (e) {
    var x = e.clientX;
    var y = e.clientY;
    cursorinner.style.left = x + "px";
    cursorinner.style.top = y + "px";
  });

  document.addEventListener("mousedown", function () {
    cursor.classList.add("click");
    cursorinner.classList.add("cursorinnerhover");
  });

  document.addEventListener("mouseup", function () {
    cursor.classList.remove("click");
    cursorinner.classList.remove("cursorinnerhover");
  });

  a.forEach((item) => {
    item.addEventListener("mouseover", () => {
      cursor.classList.add("hover");
    });
    item.addEventListener("mouseleave", () => {
      cursor.classList.remove("hover");
    });
  });
</script>
