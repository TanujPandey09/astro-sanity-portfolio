---
import Myswiper from "../../components/Slider/SliderLayout.jsx";
const data = Astro.props;
const skilldata = Astro.props;

import { PortableText } from "astro-portabletext";
import { Icon } from "astro-icon/components";
---

<!-- Animated Background -->
<div class="fixed inset-0 -z-10 bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900">
  <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-10"></div>
  <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-transparent to-transparent"></div>
</div>

<main class="min-h-screen">
  <!-- Hero Section with Image & Intro -->
  <section class="container mx-auto px-6 py-20 md:py-32">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      
      <!-- Image Section -->
      {data?.aboutData[0]?.heroImage?.asset?.url && (
        <div class="relative" data-aos="fade-right">
          <div class="absolute -inset-4 bg-gradient-to-r from-blue-500 to-purple-500 rounded-3xl blur-2xl opacity-20"></div>
          <div class="relative">
            <img
              class="w-full h-auto rounded-3xl border-2 border-slate-700/50 shadow-2xl hover:scale-[1.02] transition-transform duration-500"
              src={data.aboutData[0].heroImage.asset.url}
              alt="Profile"
            />
            <!-- Decorative Elements -->
            <div class="absolute -top-4 -right-4 w-24 h-24 bg-blue-500/20 rounded-full blur-xl"></div>
            <div class="absolute -bottom-4 -left-4 w-32 h-32 bg-purple-500/20 rounded-full blur-xl"></div>
          </div>
        </div>
      )}

      <!-- Text Content -->
      <div class="space-y-6" data-aos="fade-left">
        {data?.aboutData[0]?.aboutName && (
          <div>
            <span class="inline-block px-4 py-2 bg-blue-500/10 text-blue-400 rounded-full text-sm font-medium mb-4">
              About Me
            </span>
            <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
              {data.aboutData[0].aboutName}
            </h1>
          </div>
        )}

        <div class="prose prose-lg prose-invert">
          <PortableText
            class="text-slate-300 leading-relaxed text-lg"
            value={data?.aboutData[0]?.description}
          />
        </div>

        <!-- Social Links -->
        <div class="pt-6">
          <h3 class="text-xl font-semibold text-white mb-4 flex items-center gap-2">
            <span class="w-8 h-[2px] bg-gradient-to-r from-blue-500 to-purple-500"></span>
            Let's Connect
          </h3>
          <div class="flex gap-4">
            <a
              href="#"
              target="_blank"
              class="group relative p-4 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:border-pink-500/50 transition-all duration-300 hover:scale-110 hover:shadow-lg hover:shadow-pink-500/20"
            >
              <Icon name="instagram" size={28} class="text-slate-400 group-hover:text-pink-400 transition-colors" />
            </a>
            <a
              href="https://github.com/TanujPandey09"
              target="_blank"
              class="group relative p-4 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:border-blue-500/50 transition-all duration-300 hover:scale-110 hover:shadow-lg hover:shadow-blue-500/20"
            >
              <Icon name="github" size={28} class="text-slate-400 group-hover:text-blue-400 transition-colors" />
            </a>
            <a
              href="https://www.linkedin.com/in/tanujp09/"
              target="_blank"
              class="group relative p-4 bg-slate-800/50 rounded-xl border border-slate-700/50 hover:border-blue-500/50 transition-all duration-300 hover:scale-110 hover:shadow-lg hover:shadow-blue-500/20"
            >
              <Icon name="linkedin" size={28} class="text-slate-400 group-hover:text-blue-400 transition-colors" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section (Optional - Add your actual stats) -->
  <section class="container mx-auto px-6 py-16" data-aos="fade-up">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      <div class="text-center p-6 bg-slate-800/30 rounded-2xl border border-slate-700/50 backdrop-blur-sm hover:bg-slate-800/50 transition-all duration-300">
        <div class="text-4xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent mb-2">
          5+
        </div>
        <div class="text-slate-400 text-sm">Years Experience</div>
      </div>
      <div class="text-center p-6 bg-slate-800/30 rounded-2xl border border-slate-700/50 backdrop-blur-sm hover:bg-slate-800/50 transition-all duration-300">
        <div class="text-4xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent mb-2">
          50+
        </div>
        <div class="text-slate-400 text-sm">Projects Done</div>
      </div>
      <div class="text-center p-6 bg-slate-800/30 rounded-2xl border border-slate-700/50 backdrop-blur-sm hover:bg-slate-800/50 transition-all duration-300">
        <div class="text-4xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent mb-2">
          30+
        </div>
        <div class="text-slate-400 text-sm">Happy Clients</div>
      </div>
      <div class="text-center p-6 bg-slate-800/30 rounded-2xl border border-slate-700/50 backdrop-blur-sm hover:bg-slate-800/50 transition-all duration-300">
        <div class="text-4xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent mb-2">
          15+
        </div>
        <div class="text-slate-400 text-sm">Technologies</div>
      </div>
    </div>
  </section>

  <!-- What I Do Section -->
  <section class="container mx-auto px-6 py-16" data-aos="fade-up">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        What I Do
      </h2>
      <p class="text-slate-400 max-w-2xl mx-auto">
        I specialize in creating digital experiences that combine creativity with functionality
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <!-- Service Card 1 -->
      <div class="group p-8 bg-slate-800/30 rounded-2xl border border-slate-700/50 backdrop-blur-sm hover:bg-slate-800/50 hover:border-blue-500/50 transition-all duration-300">
        <div class="w-14 h-14 bg-blue-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-blue-500/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-white mb-3">Web Development</h3>
        <p class="text-slate-400 leading-relaxed">
          Building responsive and performant web applications using modern frameworks and best practices.
        </p>
      </div>

      <!-- Service Card 2 -->
      <div class="group p-8 bg-slate-800/30 rounded-2xl border border-slate-700/50 backdrop-blur-sm hover:bg-slate-800/50 hover:border-purple-500/50 transition-all duration-300">
        <div class="w-14 h-14 bg-purple-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-purple-500/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-white mb-3">UI/UX Design</h3>
        <p class="text-slate-400 leading-relaxed">
          Crafting beautiful and intuitive user interfaces that provide exceptional user experiences.
        </p>
      </div>

      <!-- Service Card 3 -->
      <div class="group p-8 bg-slate-800/30 rounded-2xl border border-slate-700/50 backdrop-blur-sm hover:bg-slate-800/50 hover:border-pink-500/50 transition-all duration-300">
        <div class="w-14 h-14 bg-pink-500/10 rounded-xl flex items-center justify-center mb-6 group-hover:bg-pink-500/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-pink-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-white mb-3">Product Strategy</h3>
        <p class="text-slate-400 leading-relaxed">
          Helping businesses bring their ideas to life with strategic planning and execution.
        </p>
      </div>
    </div>
  </section>

  <!-- Skills Section -->
  <section class="py-16">
    <Myswiper skilldata={skilldata} client:load />
  </section>

  <!-- CTA Section -->
  <section class="container mx-auto px-6 py-20" data-aos="fade-up">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-r from-blue-600 to-purple-600 p-12 text-center">
      <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-10"></div>
      <div class="relative z-10">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          Let's Work Together
        </h2>
        <p class="text-blue-100 mb-8 max-w-2xl mx-auto">
          I'm always interested in hearing about new projects and opportunities.
        </p>
        <a
          href="/"
          class="inline-flex items-center gap-2 px-8 py-4 bg-white text-blue-600 font-semibold rounded-xl hover:bg-blue-50 transition-all duration-300 hover:scale-105 shadow-xl"
        >
          Get In Touch
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</main>

<style>
  /* Custom Scrollbar */
  ::-webkit-scrollbar {
    width: 8px;
  }

  ::-webkit-scrollbar-track {
    background: #0f172a;
  }

  ::-webkit-scrollbar-thumb {
    background: linear-gradient(to bottom, #3b82f6, #8b5cf6);
    border-radius: 4px;
  }

  /* Prose Styling for PortableText */
  .prose {
    max-width: none;
  }

  .prose p {
    margin-bottom: 1rem;
    color: #cbd5e1;
  }

  .prose strong {
    color: #f1f5f9;
    font-weight: 600;
  }

  .prose a {
    color: #60a5fa;
    text-decoration: none;
    transition: color 0.2s;
  }

  .prose a:hover {
    color: #93c5fd;
  }

  /* Animation for background */
  @keyframes gradient-shift {
    0%, 100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  /* Smooth scroll */
  html {
    scroll-behavior: smooth;
  }
</style>