---
const { project, index } = Astro.props;
---

<div class="group relative bg-[#11172a] border border-white/5 rounded-[2rem] overflow-hidden hover:border-[#599692]/30 transition-all duration-700" data-aos="fade-up" data-aos-delay={index * 50}>
  <a href={`/projects/${project.slug.current}`} class="block aspect-[4/3] relative overflow-hidden">
    {project.BackgroundImage?.asset?.url && (
      <img 
        src={project.BackgroundImage.asset.url} 
        alt={project.projectName}
        class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-110"
      />
    )}
    <div class="absolute inset-0 bg-gradient-to-t from-[#000105] via-transparent to-transparent opacity-80 group-hover:opacity-40 transition-opacity"></div>
    
    <div class="absolute bottom-6 left-6 right-6 translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
       <div class="flex flex-wrap gap-2 mb-3 opacity-0 group-hover:opacity-100 transition-opacity">
          {project.techStack?.slice(0, 2).map((tech: string) => (
            <span class="text-[7px] font-black uppercase tracking-widest px-2 py-1 bg-white/10 rounded-full text-white/60">{tech}</span>
          ))}
       </div>
       <h4 class="text-white uppercase tracking-tighter project-card-title">{project.projectName}</h4>
    </div>
  </a>
</div>

<style>
  .project-card-title {
    font-size: clamp(var(--h4-mobile), 1.5vw, var(--h4-desktop));
    font-weight: var(--fw-bold);
  }
</style>
