---
import { useSanityClient, groq } from "astro-sanity";

const query = groq`*[_type == "blogs"]{
        ...,
        BackgroundImage{
      asset->{
        url
      }
      },
    }`;

const blogData = await useSanityClient().fetch(query);
import Blogs from "../../components/BlogLayout/Blogs";

import Layout from "../../layouts/Layout.astro";

---
<Layout title="Blogs | Tanuj Pandey" description="Read my latest technical articles, tutorials, and insights on frontend engineering, backend architecture, and AI integrations.">
  <Blogs blogData={blogData} client:load />
</Layout>
