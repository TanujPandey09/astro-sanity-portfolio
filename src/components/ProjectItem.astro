---
const { project, index } = Astro.props;
---

<div class="project-item group relative py-20 border-b border-white/5 last:border-0" data-aos="fade-up" data-aos-delay={index * 50}>
  <a href={`/projects/${project.slug.current}`} class="relative block overflow-visible">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      
      <!-- Project Metadata & Numbering -->
      <div class="lg:col-span-1 hidden lg:block">
        <div class="flex flex-col items-center">
          <span class="text-[10px] font-black text-[#599692] opacity-40 group-hover:opacity-100 transition-opacity">0{index + 1}</span>
          <div class="w-[1px] h-32 bg-gradient-to-b from-[#599692] to-transparent opacity-20 mt-4 group-hover:h-48 transition-all duration-1000"></div>
        </div>
      </div>

      <!-- Main Content -->
      <div class="lg:col-span-6 space-y-8 lg:pl-12">
        <div class="flex flex-wrap gap-3">
          {project.techStack?.slice(0, 3).map((tech: string) => (
            <span class="text-[8px] font-black uppercase tracking-[0.3em] text-[#626c7d] group-hover:text-[#599692] transition-colors">
              {tech} /
            </span>
          ))}
        </div>

        <div class="relative inline-block">
          <h3 class="text-white group-hover:text-gradient transition-all duration-700 ease-out transform group-hover:translate-x-4">
            {project.projectName}
          </h3>
          <div class="absolute -left-6 top-1/2 -translate-y-1/2 w-2 h-2 rounded-full bg-[#599692] scale-0 group-hover:scale-100 transition-transform duration-500"></div>
        </div>

        <p class="max-w-xl text-[#626c7d] group-hover:text-[#dfe5ec] transition-colors duration-500 italic leading-relaxed">
          {project.excerpt?.[0]?.children?.[0]?.text || "Architecting digital frontiers with precision and innovation."}
        </p>
        
        <div class="flex items-center gap-6 pt-4">
           <div class="text-[10px] font-black uppercase tracking-[0.4em] text-white/20 group-hover:text-white transition-colors">
             Initialize Connection
           </div>
           <div class="h-[1px] w-12 bg-white/10 group-hover:w-24 group-hover:bg-[#599692] transition-all duration-700"></div>
        </div>
      </div>

      <!-- High-Fidelity Image Preview -->
      <div class="lg:col-span-5 relative group/img">
        <div class="project-image-container relative aspect-[16/10] overflow-hidden rounded-[2rem] border border-white/5 bg-[#11172a] shadow-2xl group-hover:shadow-[#599692]/20 transition-all duration-1000">
          {project.BackgroundImage?.asset?.url && (
            <img 
              src={project.BackgroundImage.asset.url} 
              alt={project.projectName}
              class="project-image w-full h-full object-cover transition-all duration-700 ease-out grayscale group-hover:grayscale-0 group-hover:scale-110"
            />
          )}
          <!-- Overlay Effects -->
          <div class="absolute inset-0 bg-[#000105]/40 group-hover:bg-transparent transition-all duration-1000 pointer-events-none"></div>
          <div class="absolute inset-0 opacity-0 group-hover:opacity-10 bg-gradient-to-tr from-[#599692] to-transparent transition-opacity duration-1000 pointer-events-none"></div>
          
          <!-- Floating UI Elements -->
          <div class="absolute top-8 right-8 flex gap-2 items-center px-3 py-1 bg-black/40 backdrop-blur-md rounded-full border border-white/10 opacity-0 group-hover:opacity-100 transition-all duration-500">
             <div class="w-1.5 h-1.5 rounded-full bg-[#599692] animate-pulse"></div>
             <div class="text-[7px] font-black text-white/60 uppercase tracking-widest">Live Prototype</div>
          </div>
        </div>

        <!-- Background Floating Decoration -->
        <div class="absolute -bottom-8 -right-8 w-64 h-64 bg-[#599692]/5 rounded-full blur-[100px] -z-10 group-hover:bg-[#599692]/10 transition-all duration-1000"></div>
      </div>
    </div>
  </a>
</div>

<style>
  .project-item {
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  
  .project-item:hover {
    background: rgba(89, 150, 146, 0.02);
    transform: translateY(-8px);
  }

  h3 {
    font-size: clamp(var(--h3-mobile), 4vw, var(--h3-desktop));
    line-height: var(--line-height-tight);
  }
</style>

<script>
  import gsap from 'gsap';

  const items = document.querySelectorAll('.project-item');
  
  items.forEach(item => {
    const imgContainer = item.querySelector('.project-image-container');
    const img = item.querySelector('.project-image');

    if (imgContainer && img) {
      item.addEventListener('mousemove', (e: any) => {
        const { clientX, clientY } = e;
        const rect = imgContainer.getBoundingClientRect();
        const x = (clientX - rect.left - rect.width / 2) * 0.15;
        const y = (clientY - rect.top - rect.height / 2) * 0.15;

        gsap.to(img, {
          x: x,
          y: y,
          duration: 0.8,
          ease: "power2.out"
        });
      });

      item.addEventListener('mouseleave', () => {
        gsap.to(img, {
          x: 0,
          y: 0,
          duration: 0.8,
          ease: "power2.out"
        });
      });
    }
  });
</script>
