---
const { aboutData } = Astro.props;
import { PortableText } from "astro-portabletext";
import SectionHeader from "../SectionHeader.astro";
import PremiumBackground from "../PremiumBackground.astro";
import Skills from "../Skills.astro";
---

<div class="relative min-h-screen selection:bg-[#599692]/30 overflow-hidden">
  <PremiumBackground />

  <main class="container mx-auto px-6 py-16 md:py-32 relative z-10">
    <!-- Hero Section -->
    <section class="grid lg:grid-cols-12 gap-12 lg:gap-20 items-center mb-24 md:mb-48">
      <div class="lg:col-span-12 mb-12" data-aos="fade-down">
         <SectionHeader 
           title="Professional" 
           gradientText="Background" 
           subtitle="Crafting high-performance web products through engineering excellence and strategic full-stack vision."
         />
      </div>

      <!-- Image Section -->
      <div class="lg:col-span-5 relative group mb-12 lg:mb-0" data-aos="fade-right">
        <div class="absolute -inset-4 bg-gradient-to-tr from-[#599692] to-[#626c7d] rounded-[3rem] opacity-20 blur-3xl group-hover:opacity-40 transition-opacity duration-1000"></div>
        <div class="relative aspect-[4/5] rounded-3xl md:rounded-[3rem] overflow-hidden border border-white/10 p-2 bg-[#11172a] shadow-[0_0_50px_rgba(0,0,0,0.5)]">
          {aboutData?.[0]?.heroImage?.asset?.url ? (
            <img
              src={aboutData[0].heroImage.asset.url}
              alt="Tanuj Pandey"
              class="w-full h-full object-cover rounded-[2.5rem] grayscale hover:grayscale-0 transition-all duration-1000 scale-110 group-hover:scale-100 opacity-80 mix-blend-luminosity hover:mix-blend-normal"
            />
          ) : (
             <div class="w-full h-full bg-[#000105] border border-white/5 flex items-center justify-center rounded-[2.5rem]">
                <span class="font-mono text-[#599692] text-xs">NO_IMAGE_DATA</span>
             </div>
          )}
          

        </div>
        
        <!-- Abstract Element -->
        <div class="absolute -bottom-12 -right-12 w-48 h-48 bg-[#599692]/10 rounded-full blur-[80px] -z-10 group-hover:bg-[#599692]/20 transition-all"></div>
      </div>

      <!-- Content -->
      <div class="lg:col-span-7 space-y-8 md:space-y-12" data-aos="fade-left">
        <div class="prose-container relative">
          <div class="hidden md:block absolute -left-12 top-0 bottom-0 w-[1px] bg-gradient-to-b from-[#599692] via-white/10 to-transparent opacity-20"></div>
          <div class="prose prose-xl prose-invert max-w-none">
             <div class="text-white font-black uppercase tracking-tighter mb-6 md:mb-8 leading-tight h2-style">
               "{aboutData?.[0]?.aboutName || "Building robust digital products through clean engineering and technical leadership."}"
             </div>
             <div class="prose-content space-y-4 md:space-y-6">
               <PortableText value={aboutData?.[0]?.description} />
             </div>
          </div>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-6 md:gap-8 pt-8 md:pt-12">
          <div class="space-y-1.5 md:space-y-2 border-l border-[#599692]/30 pl-4">
             <p class="text-[8px] md:text-[10px] font-mono text-[#599692] uppercase tracking-[0.4em]">Experience</p>
             <p class="text-xl md:text-2xl text-white font-black tabular-nums">3.5+ Years</p>
          </div>
          <div class="space-y-1.5 md:space-y-2 border-l border-white/10 pl-4">
             <p class="text-[8px] md:text-[10px] font-mono text-[#626c7d] uppercase tracking-[0.4em]">Architecture</p>
             <p class="text-xl md:text-2xl text-white font-black tabular-nums">Scalable</p>
          </div>
          <div class="space-y-1.5 md:space-y-2 border-l border-white/10 pl-4">
             <p class="text-[8px] md:text-[10px] font-mono text-[#626c7d] uppercase tracking-[0.4em]">Stack Focus</p>
             <p class="text-xl md:text-2xl text-white font-black tabular-nums">Full Stack</p>
          </div>
        </div>
      </div>
    </section>


    <!-- Academic Background (Nerdy/Technical aesthetic) -->
    <section class="pb-16 md:pb-32 relative z-10" data-aos="fade-up">
       <div class="max-w-4xl">
          <div class="flex items-center gap-4 mb-10 md:mb-16">
             <div class="w-12 h-[1px] bg-[#599692]"></div>
             <h2 class="text-xl md:text-3xl font-black text-white uppercase tracking-tighter">Academic <span class="text-[#599692]">Foundation</span></h2>
          </div>
          
          <div class="space-y-6 md:space-y-8 pl-4 md:pl-8 border-l border-white/10 relative">
             <!-- Master's Degree -->
             <div class="relative group">
                <div class="absolute -left-[21px] md:-left-[37px] top-1.5 w-3 h-3 rounded-full bg-[#11172a] border-2 border-[#599692] group-hover:bg-[#599692] transition-colors shadow-[0_0_10px_#599692]"></div>
                <div class="bg-[#11172a]/50 border border-white/5 p-6 md:p-8 rounded-2xl group-hover:border-[#599692]/30 transition-colors">
                   <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 md:gap-4 mb-4">
                      <h3 class="text-lg md:text-xl font-bold text-white uppercase tracking-wide">Master of Computer Application</h3>
                      <span class="font-mono text-[10px] text-[#599692] bg-[#599692]/10 px-3 py-1 rounded-full">2018 – 2020</span>
                   </div>
                   <p class="text-gray-400 font-mono text-sm md:text-base">GBPEC Pauri Garhwal</p>
                </div>
             </div>

             <!-- Bachelor's Degree -->
             <div class="relative group">
                <div class="absolute -left-[21px] md:-left-[37px] top-1.5 w-3 h-3 rounded-full bg-[#11172a] border-2 border-white/20 group-hover:border-[#599692] group-hover:bg-[#599692]/50 transition-colors"></div>
                <div class="bg-[#11172a]/50 border border-white/5 p-6 md:p-8 rounded-2xl group-hover:border-[#599692]/30 transition-colors">
                   <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 md:gap-4 mb-4">
                      <h3 class="text-lg md:text-xl font-bold text-white uppercase tracking-wide">Bachelor of Computer Application</h3>
                      <span class="font-mono text-[10px] text-gray-500 bg-white/5 px-3 py-1 rounded-full">2015 – 2018</span>
                   </div>
                   <p class="text-gray-400 font-mono text-sm md:text-base">BFIT Dehradun</p>
                </div>
             </div>
          </div>
       </div>
    </section>
  </main>
  
  <!-- Skills Section added to About page -->
  <div class="relative z-20">
    <Skills />
  </div>
</div>

<style>
  .h2-style {
    font-size: clamp(var(--h2-mobile), 5vw, var(--h2-desktop));
  }
  .prose-content {
    color: #e2e8f0;
    font-size: var(--p-mobile);
    line-height: var(--line-height-relaxed);
    font-weight: 500;
  }
  @media (min-width: 1024px) {
    .prose-content {
      font-size: var(--p-desktop);
    }
  }
  .prose p {
    margin-bottom: var(--space-xl);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initAbout = () => {
    gsap.from('.prose-container', {
      opacity: 0,
      x: 50,
      duration: 1.5,
      ease: "power4.out",
      scrollTrigger: {
        trigger: '.prose-container',
        start: "top 80%"
      }
    });
  };

  initAbout();
</script>