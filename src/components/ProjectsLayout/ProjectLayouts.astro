---
import ProjectItem from "../ProjectItem.astro";
import SectionHeader from "../SectionHeader.astro";
import PremiumBackground from "../PremiumBackground.astro";
const { projectData } = Astro.props;

// Pass the initial 4 items to SSR, leave the rest for client-side infinite scroll
const initialProjects = projectData?.slice(0, 4) || [];
const remainingProjects = projectData?.slice(4) || [];
---

<div class="relative min-h-screen selection:bg-[#3B82F6]/30 overflow-hidden">
  <PremiumBackground />

  <main class="container mx-auto px-6 py-24 md:py-32 relative z-10">
    <div class="max-w-7xl mx-auto">
      <SectionHeader 
        title="Complete" 
        gradientText="Portfolio" 
        subtitle="A detailed showcase of completed platforms, professional client builds, and production-ready web applications."
      />

      <!-- Bento Grid parent container with fixed spacing -->
      <div 
        id="projects-grid" 
        class="mt-16 md:mt-24 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8"
        data-remaining={JSON.stringify(remainingProjects)}
      >
        {initialProjects.map((project: any, index: number) => (
          <ProjectItem project={project} index={index} />
        ))}
      </div>

      <!-- Infinite Scroll Trigger Element -->
      {remainingProjects.length > 0 && (
        <div id="infinite-scroll-trigger" class="h-24 w-full flex items-center justify-center mt-16">
           <div id="infinite-loader" class="flex items-center gap-3 text-[10px] font-mono font-bold text-[#22D3EE] uppercase tracking-[0.2em] opacity-0">
              <div class="w-4 h-4 border-2 border-[#22D3EE] border-t-transparent rounded-full animate-spin"></div>
              Loading digital systems...
           </div>
        </div>
      )}

      <!-- Advanced Stats (Awwwards Style) -->
      <div class="mt-24 md:mt-48 stats-grid grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12 py-12 md:py-20 border-t border-white/5">
         {[
           { label: "Completed Builds", value: "6+" },
           { label: "Commits Pushed", value: "1.2K+" },
           { label: "Success Rate", value: "100%" },
           { label: "Happy Clients", value: "25+" }
         ].map(stat => (
           <div class="space-y-4">
              <p class="text-[8px] md:text-[10px] font-black text-[#94A3B8] uppercase tracking-[0.4em] md:tracking-[0.6em]">{stat.label}</p>
              <h4 class="text-2xl md:text-4xl font-black text-white tracking-tighter tabular-nums">{stat.value}</h4>
           </div>
         ))}
      </div>
    </div>
  </main>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initArchive = () => {
    // Stagger stats reveal
    gsap.from('.stats-grid > div', {
      opacity: 0,
      y: 30,
      duration: 1,
      stagger: 0.1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: '.stats-grid',
        start: "top 90%"
      }
    });

    const grid = document.getElementById('projects-grid');
    const trigger = document.getElementById('infinite-scroll-trigger');
    const loader = document.getElementById('infinite-loader');

    if (!grid || !trigger || !loader) return;

    // Retrieve remaining projects from data attribute
    const remaining = JSON.parse(grid.getAttribute('data-remaining') || '[]');
    let currentIdx = 4; // Start index of remaining projects
    const batchSize = 4;
    let loading = false;

    // Helper to generate dynamic bento cards matching ProjectItem.astro structure
    const createProjectCardHTML = (project: any, index: number) => {
      const isWide = index % 4 === 3;
      const slug = project.slug.current;
      const name = project.projectName;
      const techStack = project.techStack || [];
      const excerpt = project.excerpt?.[0]?.children?.[0]?.text || "Production-ready digital systems built for reliability and performance.";
      const imgUrl = project.BackgroundImage?.asset?.url || "";
      
      const techHTML = techStack.slice(0, 3).map((tech: string) => `
        <span class="text-[8.5px] font-black uppercase tracking-wider text-[#94A3B8] bg-white/5 border border-white/5 px-2.5 py-1 rounded-full group-hover:text-white transition-colors">
          ${tech}
        </span>
      `).join('');

      const imgHTML = imgUrl ? `
        <div class="project-image-wrapper w-full h-full absolute inset-0">
          <img 
            src="${imgUrl}" 
            alt="${name}"
            class="project-image w-full h-full object-cover transition-all duration-[1.2s] ease-out opacity-90 group-hover:opacity-100 group-hover:scale-105"
          />
        </div>
      ` : `<div class="w-full h-full bg-[#050816]"></div>`;

      let bentoClasses = "col-span-1 ";
      if (index % 4 === 0) {
        bentoClasses += "md:col-span-2 md:row-span-2 min-h-[500px] md:min-h-[600px] flex flex-col";
      } else if (index % 4 === 1 || index % 4 === 2) {
        bentoClasses += "md:col-span-1 md:row-span-1 min-h-[300px] md:min-h-[350px] flex flex-col";
      } else {
        bentoClasses += "md:col-span-3 md:row-span-1 min-h-[280px] md:min-h-[300px] grid grid-cols-1 md:grid-cols-12";
      }

      if (isWide) {
        return `
          <div class="project-item dynamic-project-item group relative bg-[#0B1120] border border-white/5 rounded-[2rem] overflow-hidden ${bentoClasses} opacity-0 translate-y-12" data-index="${index}">
            <a href="/projects/${slug}" class="md:col-span-7 p-8 md:p-10 flex flex-col justify-between z-10 w-full h-full cursor-pointer relative">
              <div class="flex items-center justify-between">
                <div class="flex flex-wrap gap-2">
                  ${techHTML}
                </div>
                <span class="text-xs font-mono font-bold text-[#3B82F6]">/ 0${index + 1}</span>
              </div>
              <div class="mt-8 space-y-3">
                <h3 class="text-xl md:text-2xl font-black text-white uppercase tracking-tight group-hover:text-[#3B82F6] transition-colors duration-300">
                  ${name}
                </h3>
                <p class="text-xs md:text-sm text-[#F1F5F9] font-medium leading-relaxed max-w-xl">
                  ${excerpt}
                </p>
                <div class="flex items-center gap-3 pt-3">
                  <span class="text-[8px] md:text-[9px] font-black uppercase tracking-[0.2em] text-[#3B82F6] group-hover:text-white transition-colors">
                    Explore Case Study
                  </span>
                  <div class="h-[1px] w-6 bg-[#3B82F6] group-hover:w-12 transition-all duration-500 shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
                </div>
              </div>
            </a>
            <div class="md:col-span-5 relative overflow-hidden w-full h-full min-h-[200px] border-t md:border-t-0 md:border-l border-white/5">
              ${imgHTML}
              <div class="absolute inset-0 bg-gradient-to-r from-[#0B1120] to-transparent pointer-events-none md:block hidden"></div>
            </div>
          </div>
        `;
      } else {
        const imgHeightClass = index % 4 === 0 ? 'h-[62%]' : 'h-[50%]';
        return `
          <div class="project-item dynamic-project-item group relative bg-[#0B1120] border border-white/5 rounded-[2rem] overflow-hidden ${bentoClasses} opacity-0 translate-y-12" data-index="${index}">
            <div class="relative overflow-hidden w-full ${imgHeightClass} border-b border-white/5">
              ${imgHTML}
              <div class="absolute inset-0 bg-gradient-to-t from-[#0B1120]/40 to-transparent pointer-events-none"></div>
            </div>
            <a href="/projects/${slug}" class="p-6 md:p-8 flex-1 flex flex-col justify-between z-10 cursor-pointer relative">
              <div class="flex items-center justify-between">
                <div class="flex flex-wrap gap-2">
                  ${techHTML}
                </div>
                <span class="text-xs font-mono font-bold text-[#3B82F6]">/ 0${index + 1}</span>
              </div>
              <div class="mt-4 space-y-2">
                <h3 class="text-lg md:text-xl font-black text-white uppercase tracking-tight group-hover:text-[#3B82F6] transition-colors duration-300">
                  ${name}
                </h3>
                <p class="text-xs text-[#F1F5F9] font-medium leading-relaxed line-clamp-3">
                  ${excerpt}
                </p>
                <div class="flex items-center gap-3 pt-2">
                  <span class="text-[8px] md:text-[9px] font-black uppercase tracking-[0.2em] text-[#3B82F6] group-hover:text-white transition-colors">
                    Explore Case Study
                  </span>
                  <div class="h-[1px] w-6 bg-[#3B82F6] group-hover:w-12 transition-all duration-500 shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
                </div>
              </div>
            </a>
          </div>
        `;
      }
    };

    const bindParallax = (item: Element) => {
      const img = item.querySelector('.project-image');
      if (img) {
        item.addEventListener('mousemove', (e: any) => {
          const { clientX, clientY } = e;
          const rect = item.getBoundingClientRect();
          const x = (clientX - rect.left - rect.width / 2) * 0.05;
          const y = (clientY - rect.top - rect.height / 2) * 0.05;

          gsap.to(img, {
            x: x,
            y: y,
            duration: 0.6,
            ease: "power2.out"
          });
        });

        item.addEventListener('mouseleave', () => {
          gsap.to(img, {
            x: 0,
            y: 0,
            duration: 0.6,
            ease: "power2.out"
          });
        });
      }
    };

    const loadMoreProjects = () => {
      if (loading || remaining.length === 0) return;
      loading = true;

      // Show loader
      gsap.to(loader, { opacity: 1, duration: 0.3 });

      setTimeout(() => {
        const nextBatch = remaining.splice(0, batchSize);
        const tempDiv = document.createElement('div');
        let newItemsHTML = '';

        nextBatch.forEach((proj: any, idx: number) => {
          newItemsHTML += createProjectCardHTML(proj, currentIdx + idx);
        });

        tempDiv.innerHTML = newItemsHTML;
        const newElements = Array.from(tempDiv.children);

        newElements.forEach(el => {
          grid.appendChild(el);
          bindParallax(el);
        });

        currentIdx += nextBatch.length;

        // Animate elements entry
        gsap.to(newElements, {
          opacity: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.15,
          ease: "power3.out"
        });

        // Hide loader
        gsap.to(loader, { opacity: 0, duration: 0.3 });
        loading = false;

        // If no projects remain, disable scrolltrigger
        if (remaining.length === 0) {
          scrollTriggerInstance.kill();
          trigger.style.display = 'none';
        } else {
          ScrollTrigger.refresh();
        }
      }, 1000); // Small delay for immersive high-tech loading aesthetic
    };

    // ScrollTrigger to detect when user reaches the loading threshold
    const scrollTriggerInstance = ScrollTrigger.create({
      trigger: trigger,
      start: "top bottom-=100px",
      onEnter: () => loadMoreProjects()
    });
  };

  initArchive();

  document.addEventListener('astro:after-swap', () => {
    initArchive();
  });
</script>