---
const { project, index } = Astro.props;
import { getTagColor } from "../lib/colors";

// Determine grid span classes based on bento index modulo 4 to repeat layout
const bentoIndex = index % 4;
let bentoGridClasses = "col-span-1 ";
if (bentoIndex === 0) {
  // Sawt AI (Large focus card)
  bentoGridClasses += "md:col-span-2 md:row-span-2 min-h-[500px] md:min-h-[600px] flex flex-col";
} else if (bentoIndex === 1) {
  // CareAI CRM
  bentoGridClasses += "md:col-span-1 md:row-span-1 min-h-[300px] md:min-h-[350px] flex flex-col";
} else if (bentoIndex === 2) {
  // Healthcare SaaS
  bentoGridClasses += "md:col-span-1 md:row-span-1 min-h-[300px] md:min-h-[350px] flex flex-col";
} else {
  // CX Intelligence Platform (Wide horizontal card)
  bentoGridClasses += "md:col-span-3 md:row-span-1 min-h-[280px] md:min-h-[300px] grid grid-cols-1 md:grid-cols-12";
}
---

{bentoIndex === 3 ? (
  /* Wide Card: Horizontal Split (Left text, right image) */
  <div class={`project-item group relative bg-[#0B1120] border border-white/5 rounded-[2rem] overflow-hidden ${bentoGridClasses} transition-all duration-700 hover:border-[#3B82F6]/30 hover:shadow-[0_0_50px_rgba(59,130,246,0.15)]`} data-aos="fade-up" data-aos-delay={index * 100}>
    <!-- Text Content -->
    <a href={`/projects/${project.slug.current}`} class="md:col-span-7 p-8 md:p-10 flex flex-col justify-between z-10 w-full h-full cursor-pointer relative">
      <div class="flex items-center justify-between">
        <div class="flex flex-wrap gap-2">
          {project.techStack?.slice(0, 3).map((tech: string) => (
            <span class={`text-[8.5px] font-black uppercase tracking-wider border px-2.5 py-1 rounded-full transition-colors ${getTagColor(tech)}`}>
              {tech}
            </span>
          ))}
        </div>
        <span class="text-xs font-mono font-bold text-[#3B82F6]">/ 0{index + 1}</span>
      </div>

      <div class="mt-8 space-y-3">
        <h3 class="text-xl md:text-2xl font-black text-white uppercase tracking-tight group-hover:text-[#3B82F6] transition-colors duration-300">
          {project.projectName}
        </h3>
        <p class="text-xs md:text-sm text-[#F1F5F9] font-medium leading-relaxed max-w-xl">
          {project.excerpt?.[0]?.children?.[0]?.text || "Production-ready digital systems built for reliability and performance."}
        </p>
        
        <div class="flex items-center gap-3 pt-3">
          <span class="text-[8px] md:text-[9px] font-black uppercase tracking-[0.2em] text-[#3B82F6] group-hover:text-white transition-colors">
            Explore Case Study
          </span>
          <div class="h-[1px] w-6 bg-[#3B82F6] group-hover:w-12 transition-all duration-500 shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
        </div>
      </div>
    </a>

    <!-- Image Column -->
    <div class="md:col-span-5 relative overflow-hidden w-full h-full min-h-[200px] border-t md:border-t-0 md:border-l border-white/5">
      {project.BackgroundImage?.asset?.url ? (
        <div class="project-image-wrapper w-full h-full absolute inset-0">
          <img 
            src={project.BackgroundImage.asset.url} 
            alt={project.projectName}
            class="project-image w-full h-full object-cover transition-all duration-[1.2s] ease-out opacity-90 group-hover:opacity-100 group-hover:scale-105"
          />
        </div>
      ) : (
        <div class="w-full h-full bg-[#050816]"></div>
      )}
      <div class="absolute inset-0 bg-gradient-to-r from-[#0B1120] to-transparent pointer-events-none md:block hidden"></div>
    </div>
  </div>
) : (
  /* Standard/Large Card: Vertical Split (Top image, bottom text) */
  <div class={`project-item group relative bg-[#0B1120] border border-white/5 rounded-[2rem] overflow-hidden ${bentoGridClasses} transition-all duration-700 hover:border-[#3B82F6]/30 hover:shadow-[0_0_50px_rgba(59,130,246,0.15)]`} data-aos="fade-up" data-aos-delay={index * 100}>
    <!-- Top Image Container -->
    <div class={`relative overflow-hidden w-full ${bentoIndex === 0 ? 'h-[62%]' : 'h-[50%]'} border-b border-white/5`}>
      {project.BackgroundImage?.asset?.url ? (
        <div class="project-image-wrapper w-full h-full absolute inset-0">
          <img 
            src={project.BackgroundImage.asset.url} 
            alt={project.projectName}
            class="project-image w-full h-full object-cover transition-all duration-[1.2s] ease-out opacity-90 group-hover:opacity-100 group-hover:scale-105"
          />
        </div>
      ) : (
        <div class="w-full h-full bg-[#050816]"></div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-[#0B1120]/40 to-transparent pointer-events-none"></div>
    </div>

    <!-- Bottom Text Container -->
    <a href={`/projects/${project.slug.current}`} class="p-6 md:p-8 flex-1 flex flex-col justify-between z-10 cursor-pointer relative">
      <div class="flex items-center justify-between">
        <div class="flex flex-wrap gap-2">
          {project.techStack?.slice(0, 3).map((tech: string) => (
            <span class={`text-[8.5px] font-black uppercase tracking-wider border px-2.5 py-1 rounded-full transition-colors ${getTagColor(tech)}`}>
              {tech}
            </span>
          ))}
        </div>
        <span class="text-xs font-mono font-bold text-[#3B82F6]">/ 0{index + 1}</span>
      </div>

      <div class="mt-4 space-y-2">
        <h3 class="text-lg md:text-xl font-black text-white uppercase tracking-tight group-hover:text-[#3B82F6] transition-colors duration-300">
          {project.projectName}
        </h3>
        <p class="text-xs text-[#F1F5F9] font-medium leading-relaxed line-clamp-3">
          {project.excerpt?.[0]?.children?.[0]?.text || "Production-ready digital systems built for reliability and performance."}
        </p>
        
        <div class="flex items-center gap-3 pt-2">
          <span class="text-[8px] md:text-[9px] font-black uppercase tracking-[0.2em] text-[#3B82F6] group-hover:text-white transition-colors">
            Explore Case Study
          </span>
          <div class="h-[1px] w-6 bg-[#3B82F6] group-hover:w-12 transition-all duration-500 shadow-[0_0_10px_rgba(59,130,246,0.5)]"></div>
        </div>
      </div>
    </a>
  </div>
)}

<style>
  .project-item {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.5s, box-shadow 0.5s;
  }
  .project-item:hover {
    transform: translateY(-6px);
  }
</style>

<script>
  import gsap from 'gsap';

  const items = document.querySelectorAll('.project-item');
  items.forEach(item => {
    const img = item.querySelector('.project-image');
    if (img) {
      item.addEventListener('mousemove', (e: any) => {
        const { clientX, clientY } = e;
        const rect = item.getBoundingClientRect();
        const x = (clientX - rect.left - rect.width / 2) * 0.05;
        const y = (clientY - rect.top - rect.height / 2) * 0.05;

        gsap.to(img, {
          x: x,
          y: y,
          duration: 0.6,
          ease: "power2.out"
        });
      });

      item.addEventListener('mouseleave', () => {
        gsap.to(img, {
          x: 0,
          y: 0,
          duration: 0.6,
          ease: "power2.out"
        });
      });
    }
  });
</script>
