---
import ProjectItem from "../ProjectItem.astro";
import SectionHeader from "../SectionHeader.astro";
import PremiumBackground from "../PremiumBackground.astro";
const { projectData } = Astro.props;
---

<div class="relative min-h-screen selection:bg-[#599692]/30 overflow-hidden">
  <PremiumBackground />

  <main class="container mx-auto px-6 py-16 md:py-32 relative z-10">
    <div class="max-w-7xl mx-auto">
      <SectionHeader 
        title="Archive" 
        gradientText="Index" 
        subtitle="A comprehensive log of technical explorations, architectural blueprints, and high-fidelity deployments."
      />

      <div class="mt-16 md:mt-32 space-y-0">
        {projectData?.map((project: any, index: number) => (
          <ProjectItem project={project} index={index} />
        ))}
      </div>

      <!-- Advanced Stats (Awwwards Style) -->
      <div class="mt-24 md:mt-48 grid grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12 py-12 md:py-20 border-t border-white/5">
         {[
           { label: "Total Artifacts", value: "48+" },
           { label: "Lines Composed", value: "2.5M" },
           { label: "Successful Nodes", value: "100%" },
           { label: "Uptime Rating", value: "99.9%" }
         ].map(stat => (
           <div class="space-y-4">
              <p class="text-[8px] md:text-[10px] font-black text-[#626c7d] uppercase tracking-[0.4em] md:tracking-[0.6em]">{stat.label}</p>
              <h4 class="text-2xl md:text-4xl font-black text-white tracking-tighter tabular-nums">{stat.value}</h4>
           </div>
         ))}
      </div>
    </div>
  </main>
</div>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initArchive = () => {
    // Reveal project items on scroll with GSAP stagger if needed, 
    // although AOS is already doing some work.
    // Let's add a custom reveal for the stats
    gsap.from('.grid > div', {
      opacity: 0,
      y: 30,
      duration: 1,
      stagger: 0.1,
      ease: "power3.out",
      scrollTrigger: {
        trigger: '.grid',
        start: "top 90%"
      }
    });
  };

  initArchive();
</script>