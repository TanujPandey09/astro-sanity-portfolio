---
import { useSanityClient, groq } from "astro-sanity";

const query = groq`*[_type == "sideBar"]{
  ...,
  sideMenus[]->
}`;

const [sideBar] = await useSanityClient().fetch(query);
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-in-out" id="header">
  <nav class="container mx-auto px-6 py-4 transition-all duration-500" id="nav">
    <div class="flex items-center justify-between">
      {/* Logo Section */}
      <a href="/" class="group flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center group-hover:bg-[#599692]/20 transition-all duration-500">
          <span class="text-white font-black text-xl tracking-tighter group-hover:text-[#599692]">T</span>
        </div>
        <span class="text-[10px] font-black text-white uppercase tracking-[0.5em] hidden sm:block">Tanuj Pandey</span>
      </a>

      {/* Desktop Navigation */}
      <div class="hidden md:flex items-center gap-2">
        {sideBar?.sideMenus?.map((menuItem) => (
          <a 
            href={menuItem.menuLink.current}
            class="nav-link px-6 py-2 text-[10px] font-black uppercase tracking-[0.4em] text-[#626c7d] hover:text-white transition-all relative group"
          >
            <span class="relative z-10">{menuItem.menuName}</span>
            <div class="absolute inset-0 bg-white/5 rounded-full scale-0 group-hover:scale-100 transition-transform duration-500 -z-0"></div>
          </a>
        ))}
      </div>

      {/* Mobile Menu Button */}
      <button 
        id="mobile-menu-button" 
        class="md:hidden w-10 h-10 flex flex-col items-end justify-center gap-1.5 group"
      >
        <div class="w-6 h-[2px] bg-white group-hover:bg-[#599692] transition-colors"></div>
        <div class="w-4 h-[2px] bg-white group-hover:bg-[#599692] transition-colors"></div>
      </button>
    </div>

    {/* Mobile Menu Overlay */}
    <div 
      id="mobile-menu" 
      class="fixed inset-0 bg-[#000105]/95 backdrop-blur-2xl z-40 hidden flex-col items-center justify-center space-y-8"
    >
      <button id="close-menu" class="absolute top-8 right-8 text-white/40 hover:text-white text-[10px] font-black uppercase tracking-widest">Close [ESC]</button>
      {sideBar?.sideMenus?.map((menuItem) => (
        <a 
          href={menuItem.menuLink.current}
          class="text-4xl font-black text-white uppercase tracking-tighter hover:text-[#599692] transition-colors"
        >
          {menuItem.menuName}
        </a>
      ))}
    </div>
  </nav>
</header>

<style>
  #header.scrolled {
    background: rgba(17, 23, 42, 0.8);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
  
  #header.scrolled #nav {
    padding-top: 1rem;
    padding-bottom: 1rem;
  }

  .nav-link.active {
    color: #599692;
  }

  .nav-link.active div {
    scale: 1;
    background: rgba(89, 150, 146, 0.1);
  }
</style>

<script>
  const header = document.getElementById('header');
  const btn = document.getElementById('mobile-menu-button');
  const menu = document.getElementById('mobile-menu');
  const close = document.getElementById('close-menu');

  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  btn?.addEventListener('click', () => {
    menu?.classList.remove('hidden');
    menu?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  });

  const closeMenu = () => {
    menu?.classList.add('hidden');
    menu?.classList.remove('flex');
    document.body.style.overflow = '';
  };

  close?.addEventListener('click', closeMenu);
  
  // Active Link Handler
  const currentPath = window.location.pathname;
  document.querySelectorAll('.nav-link').forEach(link => {
    if (link.getAttribute('href') === currentPath) {
      link.classList.add('active');
    }
  });
</script>