---
---

<section id="contact" class="py-16 md:py-32 relative z-10 bg-[#11172a]">
  <div class="container mx-auto px-6">
    <div class="max-w-4xl mx-auto mb-12 md:mb-20 text-center" data-aos="fade-up">
       <span class="text-[8px] md:text-[10px] font-black uppercase tracking-[0.4em] md:tracking-[0.5em] text-[#599692] block mb-4 md:mb-6">Transmission Center</span>
       <h2 class="text-white mb-4 md:mb-6 contact-title uppercase tracking-tighter">Initiate <span class="text-gradient">Contact</span></h2>
       <p class="text-gray-400 italic contact-subtitle max-w-2xl mx-auto">
         "Have a project in mind? Let's discuss how we can bring your ideas to life."
       </p>
    </div>

    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 max-w-7xl mx-auto">
      <!-- Info Hub -->
      <div class="lg:col-span-5 space-y-6 md:space-y-8" data-aos="fade-right">
         <div class="p-8 md:p-10 rounded-3xl md:rounded-[3rem] glass-card space-y-8 md:space-y-12 relative overflow-hidden group">
            <div class="absolute top-0 right-0 w-32 h-32 bg-[#599692]/5 rounded-full blur-3xl -z-10"></div>
            
            <a href="mailto:tanujp09@gmail.com" class="flex items-center gap-5 md:gap-6 group/link">
               <div class="w-12 h-12 md:w-14 md:h-14 rounded-xl md:rounded-2xl bg-white/5 flex items-center justify-center text-white/40 group-hover/link:bg-[#599692] group-hover/link:text-white transition-all duration-500 shrink-0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-5 h-5 md:w-6 md:h-6"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
               </div>
               <div>
                  <p class="text-[8px] md:text-[10px] font-black text-white/20 uppercase tracking-widest mb-1">Secure Channel</p>
                  <p class="text-sm md:text-base text-white font-bold group-hover/link:text-[#599692] transition-colors break-all">tanujp09@gmail.com</p>
               </div>
            </a>

            <div class="flex items-center gap-5 md:gap-6 group/link">
               <div class="w-12 h-12 md:w-14 md:h-14 rounded-xl md:rounded-2xl bg-white/5 flex items-center justify-center text-white/40 shrink-0">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-5 h-5 md:w-6 md:h-6"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
               </div>
               <div>
                  <p class="text-[8px] md:text-[10px] font-black text-white/20 uppercase tracking-widest mb-1">Geographic Node</p>
                  <p class="text-sm md:text-base text-white font-bold">Delhi, India</p>
               </div>
            </div>

            <div class="pt-6 md:pt-8 border-t border-white/5 flex gap-3 md:gap-4">
               <a href="https://github.com/TanujPandey09" target="_blank" class="w-10 h-10 md:w-12 md:h-12 rounded-lg md:rounded-xl bg-white/5 flex items-center justify-center hover:bg-white hover:text-black transition-all">
                  <svg fill="currentColor" viewBox="0 0 24 24" class="w-[18px] h-[18px] md:w-5 md:h-5"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23a11.509 11.509 0 0 0-3.007-.403c-1.02.005-2.047.138-3.006.404-2.291-1.552-3.297-1.23-3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
               </a>
               <a href="https://linkedin.com/in/tanujdev" target="_blank" class="w-10 h-10 md:w-12 md:h-12 rounded-lg md:rounded-xl bg-white/5 flex items-center justify-center hover:bg-[#0077b5] hover:text-white transition-all">
                  <svg fill="currentColor" viewBox="0 0 24 24" class="w-[18px] h-[18px] md:w-5 md:h-5"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
               </a>
            </div>
         </div>
      </div>

      <!-- Form Center -->
      <div class="lg:col-span-7" data-aos="fade-left">
         <form id="contactForm" class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-8">
            <div class="space-y-3 md:space-y-4">
               <label class="text-[8px] md:text-[10px] font-black text-white/20 uppercase tracking-widest ml-4">Full Identity</label>
               <input type="text" name="from_name" required placeholder="User-01" class="w-full bg-white/5 border border-white/10 rounded-xl md:rounded-2xl px-5 md:px-6 py-3 md:py-4 text-white focus:outline-none focus:border-[#599692] transition-all text-sm" />
            </div>
            <div class="space-y-3 md:space-y-4">
               <label class="text-[8px] md:text-[10px] font-black text-white/20 uppercase tracking-widest ml-4">Neural Path (Email)</label>
               <input type="email" name="from_email" required placeholder="access@network.com" class="w-full bg-white/5 border border-white/10 rounded-xl md:rounded-2xl px-5 md:px-6 py-3 md:py-4 text-white focus:outline-none focus:border-[#599692] transition-all text-sm" />
            </div>
            <div class="md:col-span-2 space-y-3 md:space-y-4">
               <label class="text-[8px] md:text-[10px] font-black text-white/20 uppercase tracking-widest ml-4">Frequency (Subject)</label>
               <input type="text" name="subject" required placeholder="Project Architecture" class="w-full bg-white/5 border border-white/10 rounded-xl md:rounded-2xl px-5 md:px-6 py-3 md:py-4 text-white focus:outline-none focus:border-[#599692] transition-all text-sm" />
            </div>
            <div class="md:col-span-2 space-y-3 md:space-y-4">
               <label class="text-[8px] md:text-[10px] font-black text-white/20 uppercase tracking-widest ml-4">Transmission (Message)</label>
               <textarea name="message" required rows="5" placeholder="System briefing..." class="w-full bg-white/5 border border-white/10 rounded-2xl md:rounded-3xl px-5 md:px-6 py-4 md:py-6 text-white focus:outline-none focus:border-[#599692] transition-all resize-none text-sm"></textarea>
            </div>
            <div class="md:col-span-2">
               <button type="submit" class="group relative px-12 py-5 md:py-6 bg-white text-black font-black uppercase text-[10px] tracking-[0.4em] overflow-hidden rounded-full transition-all duration-500 hover:scale-[1.02] w-full">
                  <span class="relative z-10 flex items-center justify-center gap-4">
                    Send Transmission
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                  </span>
                  <div class="absolute inset-0 bg-[#599692] translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-500 -z-0"></div>
               </button>
            </div>
         </form>
         <div id="form-status" class="mt-8 text-center text-[10px] font-black uppercase tracking-[0.2em] hidden"></div>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const status = document.getElementById('form-status');

  const showStatus = (msg: string, isError = false) => {
    if (!status) return;
    status.textContent = msg;
    status.className = `mt-8 text-center text-[10px] font-black uppercase tracking-[0.2em] ${isError ? 'text-red-500' : 'text-[#599692]'}`;
    status.classList.remove('hidden');
    setTimeout(() => status.classList.add('hidden'), 5000);
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const originalText = submitBtn.innerHTML;
    
    submitBtn.disabled = true;
    submitBtn.innerHTML = "Processing...";

    const formData = new FormData(form);
    const data = {
      service_id: 'service_opjht2n',
      template_id: 'template_0ba37iw',
      user_id: 'zRwjESLpvAhSCrIc5',
      template_params: {
        from_name: formData.get('from_name'),
        from_email: formData.get('from_email'),
        subject: formData.get('subject'),
        message: formData.get('message'),
        to_email: 'tanujp09@gmail.com'
      }
    };

    try {
      const resp = await fetch('https://api.emailjs.com/api/v1.0/email/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (resp.ok) {
        showStatus('✅ Transmission Successful');
        form.reset();
      } else {
        throw new Error();
      }
    } catch {
      showStatus('❌ Transmission Failure', true);
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });
</script>

<style>
  .contact-title {
    font-size: clamp(var(--h2-mobile), 5vw, var(--h2-desktop));
  }
  .contact-subtitle {
     font-size: clamp(var(--p-mobile), 1.5vw, var(--p-desktop));
  }
</style>
