---
import { useSanityClient, groq } from "astro-sanity";
import ProjectDetails from "../../components/ProjectsLayout/ProjectDetails.astro";
import Layout from "../../layouts/Layout.astro";
export const prerender = true;


export async function getStaticPaths() {
  const blogs = await useSanityClient().fetch(
  groq`*[_type == "projects"]{
        ...,
        BackgroundImage{
      asset->{
        url
      }
      },
    }`
  );
  return blogs.map((items) => {
   
    return {
      params: { slug: items.slug?.current },
      props: {
        detailsData: items,
      },
    };
  });
}
const { detailsData } = Astro.props;

// Extract a plain text description from Portable Text for SEO
const projectDescription = detailsData?.excerpt?.[0]?.children?.[0]?.text 
  || "View the complete case study for this digital platform built with modern web architecture.";
  
const ogImage = detailsData?.BackgroundImage?.asset?.url || "https://tanujdev.netlify.app/favicon.svg";
---

<Layout title={`${detailsData?.projectName} - Tanuj Pandey`} description={projectDescription} image={ogImage}>
  <ProjectDetails detailsData={detailsData} />
</Layout>
