---
const { detailsData } = Astro.props;
import { PortableText } from "astro-portabletext";
import PremiumBackground from "../PremiumBackground.astro";
---

<div class="relative min-h-screen selection:bg-[#599692]/30 overflow-hidden">
  <PremiumBackground />

  <main class="container mx-auto px-6 py-32 relative z-10">
    <!-- Breadcrumb / Meta -->
    <div class="mb-16 flex items-center justify-between" data-aos="fade-down">
       <a href="/projects" class="group flex items-center gap-4 text-[10px] font-black uppercase tracking-[0.5em] text-[#626c7d] hover:text-[#599692] transition-colors">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="group-hover:-translate-x-2 transition-transform">
            <path d="M19 12H5m7-7-7 7 7 7"/>
          </svg>
          Back to Index
       </a>
       <div class="text-[10px] font-black text-[#599692] uppercase tracking-[0.5em] opacity-40">Artifact NR. {detailsData?._id?.slice(-4) || "001"}</div>
    </div>

    <!-- Project Identity -->
    <section class="max-w-7xl mx-auto mb-32">
       <div class="grid lg:grid-cols-12 gap-16 items-end mb-24">
          <div class="lg:col-span-8 space-y-8" data-aos="fade-right">
             <div class="flex items-center gap-3">
                <div class="h-[1px] w-12 bg-[#599692]"></div>
                <span class="text-[10px] font-black uppercase tracking-[0.4em] text-[#599692]">Deployment Log</span>
             </div>
             <h1 class="text-6xl md:text-8xl lg:text-9xl font-black text-white uppercase tracking-tighter leading-none m-0">
               {detailsData?.projectName}
             </h1>
          </div>
          <div class="lg:col-span-4 flex flex-wrap gap-4 pb-4" data-aos="fade-left">
             {detailsData?.tags?.map((tag: string) => (
                <span class="px-5 py-2 rounded-full border border-white/10 text-[10px] font-black uppercase tracking-widest text-[#626c7d]">
                  {tag}
                </span>
             ))}
          </div>
       </div>

       <!-- Hero Image / Artifact -->
       <div class="relative rounded-[3rem] overflow-hidden border border-white/5 bg-[#11172a] group" data-aos="zoom-out">
          {detailsData?.BackgroundImage?.asset?.url && (
            <img 
              src={detailsData.BackgroundImage.asset.url} 
              alt={detailsData.projectName}
              class="w-full h-auto object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 scale-105 group-hover:scale-100"
            />
          )}
          <div class="absolute inset-0 bg-gradient-to-t from-[#11172a]/80 via-transparent to-transparent"></div>
          
          <!-- Quick Status UI overlay -->
          <div class="absolute bottom-12 left-12 right-12 flex flex-col md:flex-row justify-between items-end gap-8">
             <div className="space-y-4">
                <p className="text-[10px] font-black text-white/40 uppercase tracking-[0.4em]">Node Distribution</p>
                <div className="flex gap-2">
                   {[1,2,3,4,5,6].map(i => <div key={i} className={`h-1 w-8 rounded-full ${i <= 4 ? 'bg-[#599692]' : 'bg-white/10'}`}></div>)}
                </div>
             </div>
             <div class="flex gap-6">
                {detailsData?.demoLink?.current && (
                  <a href={detailsData.demoLink.current} target="_blank" class="px-10 py-5 bg-white text-black font-black uppercase text-[10px] tracking-[0.4em] rounded-full hover:bg-[#599692] hover:text-white transition-all duration-500 shadow-2xl">
                    Live Interface
                  </a>
                )}
                {detailsData?.gitHubLink?.current && (
                  <a href={detailsData.gitHubLink.current} target="_blank" class="px-10 py-5 bg-white/5 backdrop-blur-md border border-white/10 text-white font-black uppercase text-[10px] tracking-[0.4em] rounded-full hover:bg-white/10 transition-all">
                    Source Intel
                  </a>
                )}
             </div>
          </div>
       </div>
    </section>

    <!-- Project Intelligence -->
    <section class="max-w-5xl mx-auto py-32 border-t border-white/5">
       <div class="grid lg:grid-cols-12 gap-20">
          <div class="lg:col-span-4" data-aos="fade-right">
             <h2 class="text-2xl font-black text-white uppercase tracking-tighter mb-8 leading-tight">Technical <br/> <span class="text-gradient">Specifications</span></h2>
             <div class="space-y-8">
                <div class="space-y-2">
                   <p class="text-[10px] font-black text-[#599692] uppercase tracking-[0.4em]">Architect</p>
                   <p class="text-sm text-white font-medium uppercase">Tanuj Pandey</p>
                </div>
                <div class="space-y-2">
                   <p class="text-[10px] font-black text-[#626c7d] uppercase tracking-[0.4em]">Date of Launch</p>
                   <p class="text-sm text-white font-medium uppercase font-mono">{new Date(detailsData?._createdAt).toLocaleDateString()}</p>
                </div>
                <div class="space-y-2">
                   <p class="text-[10px] font-black text-[#626c7d] uppercase tracking-[0.4em]">Status</p>
                   <div class="flex items-center gap-2">
                      <div class="w-2 h-2 rounded-full bg-[#599692] animate-pulse"></div>
                      <p class="text-sm text-white font-medium uppercase tracking-widest">Active</p>
                   </div>
                </div>
             </div>
          </div>
          
          <div class="lg:col-span-8" data-aos="fade-left">
             <div class="prose-custom">
               <PortableText value={detailsData?.projectcontent} />
             </div>
          </div>
       </div>
    </section>
  </main>
</div>

<style>
  .prose-custom {
    @apply text-[#626c7d] text-lg md:text-xl leading-relaxed italic;
  }
  .prose-custom :global(p) {
    @apply mb-10;
  }
  .prose-custom :global(h2) {
    @apply text-white text-3xl font-black uppercase tracking-tighter mt-16 mb-8;
  }
  .prose-custom :global(strong) {
    @apply text-white font-black uppercase;
  }
</style>