---
const { project, index } = Astro.props;
---

<div class="project-item group relative py-12 border-b border-white/5 last:border-0" data-aos="fade-up" data-aos-delay={index * 100}>
  <a href={`/projects/${project.slug.current}`} class="flex flex-col md:flex-row items-center justify-between gap-12 group">
    <div class="flex-1 space-y-6">
      <div class="flex items-center gap-4">
        <span class="text-[10px] font-black text-[#599692] opacity-40">0{index + 1}</span>
        <div class="h-[1px] w-8 bg-[#599692] opacity-20 group-hover:w-16 transition-all duration-700"></div>
      </div>
      
      <h3 class="text-4xl md:text-7xl font-black text-white group-hover:text-[#599692] transition-colors uppercase tracking-tighter">
        {project.projectName}
      </h3>
      
      <p class="text-[#626c7d] text-lg md:text-xl max-w-xl italic line-clamp-2">
        {project.excerpt?.[0]?.children?.[0]?.text || "Architecting digital frontiers with precision and innovation."}
      </p>

      <div class="flex flex-wrap gap-3 pt-4">
        {project.techStack?.slice(0, 3).map((tech: string) => (
          <span class="px-4 py-1.5 rounded-full bg-white/5 border border-white/10 text-[8px] font-black uppercase tracking-widest text-white/40 group-hover:text-white transition-colors">
            {tech}
          </span>
        ))}
      </div>
    </div>

    <div class="relative w-full md:w-1/2 aspect-video overflow-hidden rounded-[2rem] border border-white/5">
      {project.BackgroundImage?.asset?.url && (
        <img 
          src={project.BackgroundImage.asset.url} 
          alt={project.projectName}
          class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-1000 group-hover:scale-110"
        />
      )}
      <div class="absolute inset-0 bg-[#11172a]/40 group-hover:bg-transparent transition-all duration-700"></div>
      
      <div class="absolute bottom-6 right-6 px-6 py-3 bg-white text-black text-[10px] font-black uppercase tracking-[0.3em] rounded-full translate-y-12 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
        View Intel
      </div>
    </div>
  </a>
</div>

<style>
  .project-item {
    transition: background-color 0.5s ease;
  }
  .project-item:hover {
    background: rgba(89, 150, 146, 0.02);
  }
</style>
