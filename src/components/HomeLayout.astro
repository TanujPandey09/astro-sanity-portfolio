---
import { useSanityClient, groq } from "astro-sanity";
import BlogSlider from "../components/Slider/BlogSlider.jsx";
import ProjectSlider from "../components/Slider/ProjectSlider";
import AIChatbot from "./AiChatbot";
import "slick-carousel/slick/slick.css";
import "slick-carousel/slick/slick-theme.css";

const query = groq`*[_type == "projects"]{...,BackgroundImage{asset->{url}}}`;
const blogquery = groq`*[_type == "blogs"]{...,FeatureImage{asset->{url}}}`;

const projectData = await useSanityClient().fetch(query);
const blogData = await useSanityClient().fetch(blogquery);

const experienceData = [
  {
    role: "FullStack Developer",
    company: "CxiSuite",
    duration: "Sep 2025 - Present",
    type: "Remote",
    companyUrl: "https://cxisuite.com/",
    description: "Web Development",
    technologies: [
      { name: "React.js", color: "bg-sky-500" },
      { name: "Material UI", color: "bg-emerald-500" },
      { name: "React Native", color: "bg-indigo-500" },
      { name: "Axios", color: "bg-amber-500" },
      { name: "REST API", color: "bg-rose-500" },
      { name: "Replit AI", color: "bg-purple-500" },
      { name: "GoDaddy", color: "bg-teal-500" },
    ],
    logo: "https://cxisuite.com/assets/logo1_1757929917544-2LY1vMCS.png",
  },
  {
    role: "Frontend Developer",
    company: "Nasyat IT",
    duration: "Feb 2025 - July 2025",
    type: "Remote",
    companyUrl: "https://www.nasyait.com/",
    description: "Developed a complete Hospital Management System using React.js, Material UI, and React Native. Built appointment booking, case sheet, and reports modules. Integrated REST APIs with Axios, improving performance by 20%.",
