---
import { useSanityClient, groq } from "astro-sanity";

const query = groq`*[_type == "sideBar"]{
  ...,
  sideMenus[]->
}`;

const [sideBar] = await useSanityClient().fetch(query);
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-700 pointer-events-none" id="main-header">
  <!-- Subtle Header Background Blur -->
  <div class="absolute inset-0 header-bg transition-all duration-700"></div>

  <nav class="w-full px-6 py-6 flex items-center justify-between transition-all duration-700 relative z-10 pointer-events-auto" id="nav-container">
    
    <!-- LEFT: System Stats Node -->
    <div class="hidden lg:flex items-center gap-6 flex-1">
       
       
       <a href="/" class="flex items-center gap-4 group">
          <div class="w-10 h-10 bg-white/5 border border-white/10 rounded-xl flex items-center justify-center group-hover:border-[#599692] transition-colors overflow-hidden">
             <span class="text-white font-black text-lg tracking-tighter relative z-10">TP</span>
          </div>
          <p class="text-[10px] font-black text-white uppercase tracking-[0.4em] group-hover:text-[#599692] transition-colors">Tanuj Pandey</p>
       </a>
    </div>

    <!-- CENTER: Floating Pill Navigation -->
    <div class="flex-none md:flex-1 flex justify-center order-1 md:order-none">
       <div class="flex items-center gap-2 p-1 bg-black/40 backdrop-blur-3xl border border-white/5 rounded-full px-4 py-1.5">
          {sideBar?.sideMenus?.map((menuItem) => (
             <a 
               href={menuItem.menuLink.current}
               class="nav-link px-6 py-2.5 text-[10px] font-black uppercase tracking-[0.3em] text-[#626c7d] hover:text-white transition-all rounded-full relative group"
             >
               <span class="relative z-10">{menuItem.menuName}</span>
               <div class="active-pill absolute inset-0 bg-[#599692]/10 rounded-full scale-0 transition-all duration-500 group-hover:scale-100"></div>
             </a>
          ))}
          
          <!-- Mobile Menu Trigger (Visible on mobile within the pill) -->
          <button 
            id="mobile-trigger"
            class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 group ml-2"
          >
             <div class="w-5 h-[1.5px] bg-[#599692] transition-all" id="bar-1"></div>
             <div class="w-5 h-[1.5px] bg-white transition-all" id="bar-2"></div>
          </button>
       </div>
    </div>

    <!-- RIGHT: Interface Meta -->
   
  </nav>

  <!-- Mobile Overlay -->
  <div id="mobile-overlay" class="fixed inset-0 bg-[#000105]/98 backdrop-blur-2xl z-40 hidden flex-col items-center justify-center pointer-events-auto">
     <div class="space-y-12 text-center">
        {sideBar?.sideMenus?.map((menuItem, index) => (
          <a 
            href={menuItem.menuLink.current}
            class="mobile-nav-link block text-5xl font-black text-white uppercase tracking-tighter hover:text-[#599692] transition-all relative group"
            style={`animation-delay: ${index * 0.1}s`}
          >
            {menuItem.menuName}
          </a>
        ))}
     </div>
     <button id="close-overlay" class="mt-20 px-8 py-3 border border-white/10 rounded-full text-[8px] font-black uppercase tracking-widest text-white">Terminate [ESC]</button>
  </div>
</header>

<style>
  header .header-bg {
    background: transparent;
    border-bottom: 1px solid transparent;
  }

  #main-header.scrolled .header-bg {
    background: rgba(0, 1, 5, 0.4);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .nav-link.active .active-pill {
    scale: 1;
    background: rgba(89, 150, 146, 0.15);
  }

  .nav-link.active span {
    color: white;
  }

  @keyframes slideReveal {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .mobile-nav-link {
    animation: slideReveal 0.8s forwards ease-out;
  }
</style>

<script>
  import gsap from 'gsap';

  const header = document.getElementById('main-header');
  const trigger = document.getElementById('mobile-trigger');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn = document.getElementById('close-overlay');
  const navItems = document.querySelectorAll('.nav-link');

  // Scroll Behavior
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });

  // Mobile Toggle
  const openMenu = () => {
    overlay?.classList.remove('hidden');
    overlay?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    overlay?.classList.add('hidden');
    overlay?.classList.remove('flex');
    document.body.style.overflow = '';
  };

  trigger?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);

  // Active State Management
  const currentPath = window.location.pathname;
  navItems.forEach(item => {
    const href = item.getAttribute('href');
    if (href === currentPath || (currentPath === '/' && href === '/')) {
      item.classList.add('active');
    }
  });

  // Entrance
  window.addEventListener('portfolio-loaded', () => {
    gsap.from('#nav-container > div', {
      opacity: 0,
      y: -20,
      duration: 1,
      stagger: 0.2,
      ease: "power4.out"
    });
  });
</script>