---
const data = Astro.props;
import { PortableText } from "astro-portabletext";
---

<section class="min-h-screen relative overflow-hidden font-Roboto">
  <!-- Premium Animated Background (Same as project listing) -->
  <div class="fixed inset-0 -z-10">
    <!-- Base gradient with animation -->
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-purple-950 to-slate-900 animate-gradient-shift"></div>
    
    <!-- Animated mesh gradient overlay -->
    <div class="absolute inset-0 opacity-60">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-purple-500/30 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
      <div class="absolute top-0 right-1/4 w-96 h-96 bg-violet-500/30 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
      <div class="absolute bottom-0 left-1/3 w-96 h-96 bg-indigo-500/30 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-4000"></div>
    </div>
    
    <!-- Floating particles -->
    <div class="particles-container">
      <div class="particle particle-1"></div>
      <div class="particle particle-2"></div>
      <div class="particle particle-3"></div>
      <div class="particle particle-4"></div>
      <div class="particle particle-5"></div>
      <div class="particle particle-6"></div>
      <div class="particle particle-7"></div>
      <div class="particle particle-8"></div>
    </div>
    
    <!-- Animated lines -->
    <div class="lines-container">
      <div class="line line-1"></div>
      <div class="line line-2"></div>
      <div class="line line-3"></div>
    </div>
    
    <!-- Sophisticated grid with animation -->
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.03] animate-grid-float"></div>
    
    <!-- Pulsing rings -->
    <div class="rings-container">
      <div class="ring ring-1"></div>
      <div class="ring ring-2"></div>
      <div class="ring ring-3"></div>
    </div>
    
    <!-- Radial gradient vignette -->
    <div class="absolute inset-0 bg-radial-gradient"></div>
  </div>

  <div class="container mx-auto px-4 md:px-8 lg:px-12 py-12 md:py-20">
    <!-- Back Button -->
    <div class="mb-8 animate-fade-in">
      <a 
        href="/projects" 
        class="inline-flex items-center gap-2 px-6 py-3 bg-slate-800/60 hover:bg-slate-700/60 backdrop-blur-sm border border-white/10 hover:border-purple-500/30 rounded-xl text-gray-300 hover:text-white transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/10 group"
      >
        <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
        <span class="font-medium">Back to Projects</span>
      </a>
    </div>

    <!-- Main Content Container -->
    <article class="max-w-5xl mx-auto">
      <!-- Header Section -->
      <header class="mb-12 animate-fade-in-up">
        <div class="relative inline-block mb-6">
          <h1 class="text-4xl md:text-6xl lg:text-7xl font-black text-white leading-tight">
            {data?.detailsData?.projectName}
          </h1>
          <!-- Decorative underline -->
          <div class="mt-4 h-1.5 bg-gradient-to-r from-purple-500 via-violet-500 to-purple-600 rounded-full animate-expand-line"></div>
        </div>

        <!-- Project Meta Info -->
        {data?.detailsData?.tags && (
          <div class="flex flex-wrap gap-3 mb-6">
            {data.detailsData.tags.map((tag) => (
              <span class="inline-flex items-center px-4 py-2 bg-slate-800/60 backdrop-blur-sm border border-purple-500/20 rounded-xl text-sm font-medium text-purple-300 hover:bg-purple-600/20 hover:border-purple-400/40 transition-all duration-300">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>

      <!-- Featured Image with Premium Frame -->
      <div class="mb-16 animate-fade-in-up animation-delay-200">
        <div class="group relative overflow-hidden rounded-3xl bg-gradient-to-br from-slate-900/50 to-slate-800/50 backdrop-blur-xl border border-white/10 shadow-2xl hover:shadow-purple-500/20 transition-all duration-700">
          
          <!-- Image Container -->
          <div class="relative overflow-hidden">
            <img 
              src={`${data?.detailsData?.BackgroundImage?.asset?.url}`}
              alt={data?.detailsData?.projectName}
              class="w-full h-auto object-cover transition-transform duration-700 group-hover:scale-105"
            />
            
            <!-- Gradient Overlays -->
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            
            <!-- Shine Effect -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none">
              <div class="absolute inset-0 bg-gradient-to-br from-transparent via-white/10 to-transparent transform -translate-x-full group-hover:translate-x-full transition-transform duration-1000"></div>
            </div>

            <!-- Corner Accents -->
            <div class="absolute top-0 left-0 w-20 h-20 border-t-4 border-l-4 border-purple-500/40 rounded-tl-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="absolute bottom-0 right-0 w-20 h-20 border-b-4 border-r-4 border-purple-500/40 rounded-br-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          </div>

          <!-- Image Caption -->
          <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-slate-900/90 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500">
            <p class="text-gray-300 text-sm font-medium">Project Preview</p>
          </div>
        </div>
      </div>

      <!-- Project Links Section -->
      {(data?.detailsData?.gitHubLink || data?.detailsData?.demoLink) && (
        <div class="mb-16 animate-fade-in-up animation-delay-300">
          <div class="flex flex-wrap gap-4 justify-center md:justify-start">
            {data?.detailsData?.gitHubLink && (
              <a
                href={data.detailsData.gitHubLink.current}
                target="_blank"
                rel="noopener noreferrer"
                class="group/github flex items-center gap-3 px-8 py-4 bg-slate-800/60 hover:bg-slate-700/60 backdrop-blur-sm border border-white/10 hover:border-purple-500/30 rounded-2xl text-gray-300 hover:text-white transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/20 hover:scale-105"
              >
                <svg class="w-6 h-6 group-hover/github:rotate-12 transition-transform duration-300" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                <span class="font-semibold text-lg">View Source Code</span>
              </a>
            )}
            
            {data?.detailsData?.demoLink && (
              <a
                href={data.detailsData.demoLink.current}
                target="_blank"
                rel="noopener noreferrer"
                class="group/demo flex items-center gap-3 px-8 py-4 bg-gradient-to-r from-purple-600 to-violet-600 hover:from-purple-500 hover:to-violet-500 rounded-2xl text-white transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/50 hover:scale-105"
              >
                <span class="font-bold text-lg">Visit Live Demo</span>
                <svg class="w-6 h-6 group-hover/demo:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
              </a>
            )}
          </div>
        </div>
      )}

      <!-- Content Section -->
      <div class="animate-fade-in-up animation-delay-400">
        <div class="relative bg-gradient-to-br from-slate-900/50 to-slate-800/50 backdrop-blur-xl rounded-3xl border border-white/10 shadow-2xl overflow-hidden">
          
          <!-- Decorative corner elements -->
          <div class="absolute top-0 right-0 w-40 h-40 bg-gradient-to-br from-purple-500/10 to-transparent rounded-bl-full"></div>
          <div class="absolute bottom-0 left-0 w-40 h-40 bg-gradient-to-tr from-violet-500/10 to-transparent rounded-tr-full"></div>

          <!-- Content -->
          <div class="relative p-8 md:p-12 lg:p-16">
            <!-- Section Title -->
            <div class="mb-8">
              <h2 class="text-3xl md:text-4xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-violet-400 mb-3">
                About This Project
              </h2>
              <div class="w-20 h-1 bg-gradient-to-r from-purple-500 to-violet-500 rounded-full"></div>
            </div>

            <!-- Portable Text Content with Enhanced Styling -->
            <div class="prose-custom">
              <PortableText
                class="text-gray-300 text-lg leading-relaxed"
                value={data?.detailsData?.projectcontent}
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Navigation Footer -->
      <footer class="mt-16 pt-12 border-t border-white/10 animate-fade-in-up animation-delay-500">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
          <a 
            href="/projects" 
            class="inline-flex items-center gap-2 px-6 py-3 bg-slate-800/60 hover:bg-slate-700/60 backdrop-blur-sm border border-white/10 hover:border-purple-500/30 rounded-xl text-gray-300 hover:text-white transition-all duration-300 hover:shadow-lg hover:shadow-purple-500/10 group"
          >
            <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            <span class="font-medium">View All Projects</span>
          </a>

          <div class="flex items-center gap-4">
            <span class="text-gray-400 text-sm">Share this project:</span>
            <div class="flex gap-3">
              <button class="w-10 h-10 flex items-center justify-center bg-slate-800/60 hover:bg-purple-600/30 backdrop-blur-sm border border-white/10 hover:border-purple-500/30 rounded-lg text-gray-300 hover:text-white transition-all duration-300 hover:scale-110">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"></path>
                </svg>
              </button>
              <button class="w-10 h-10 flex items-center justify-center bg-slate-800/60 hover:bg-purple-600/30 backdrop-blur-sm border border-white/10 hover:border-purple-500/30 rounded-lg text-gray-300 hover:text-white transition-all duration-300 hover:scale-110">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"></path>
                </svg>
              </button>
              <button class="w-10 h-10 flex items-center justify-center bg-slate-800/60 hover:bg-purple-600/30 backdrop-blur-sm border border-white/10 hover:border-purple-500/30 rounded-lg text-gray-300 hover:text-white transition-all duration-300 hover:scale-110">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"></path>
                  <circle cx="4" cy="4" r="2"></circle>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </footer>
    </article>
  </div>
</section>

<style>
  /* Same animations as project listing page */
  @keyframes blob {
    0%, 100% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(20px, -50px) scale(1.1); }
    50% { transform: translate(-20px, 20px) scale(0.9); }
    75% { transform: translate(50px, 50px) scale(1.05); }
  }

  @keyframes gradient-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  @keyframes float-particle {
    0%, 100% { 
      transform: translate(0, 0) rotate(0deg);
      opacity: 0.3;
    }
    25% { 
      transform: translate(30px, -30px) rotate(90deg);
      opacity: 0.6;
    }
    50% { 
      transform: translate(-20px, -60px) rotate(180deg);
      opacity: 0.4;
    }
    75% { 
      transform: translate(40px, -40px) rotate(270deg);
      opacity: 0.5;
    }
  }

  @keyframes draw-line {
    0% {
      transform: translateX(-100%) translateY(0);
      opacity: 0;
    }
    50% {
      opacity: 0.3;
    }
    100% {
      transform: translateX(100vw) translateY(0);
      opacity: 0;
    }
  }

  @keyframes pulse-ring {
    0% {
      transform: scale(0.8);
      opacity: 0.8;
    }
    50% {
      transform: scale(1.2);
      opacity: 0.4;
    }
    100% {
      transform: scale(1.5);
      opacity: 0;
    }
  }

  @keyframes grid-float {
    0%, 100% {
      transform: translateY(0) translateX(0);
    }
    50% {
      transform: translateY(-10px) translateX(5px);
    }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes expand-line {
    from { width: 0; }
    to { width: 100%; }
  }

  .animate-blob {
    animation: blob 7s infinite;
  }

  .animation-delay-2000 {
    animation-delay: 2s;
  }

  .animation-delay-4000 {
    animation-delay: 4s;
  }

  .animate-gradient-shift {
    background: linear-gradient(-45deg, #020617, #581c87, #1e293b, #6d28d9, #020617);
    background-size: 400% 400%;
    animation: gradient-shift 15s ease infinite;
  }

  .animate-grid-float {
    animation: grid-float 20s ease-in-out infinite;
  }

  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.8s ease-out forwards;
    opacity: 0;
  }

  .animate-expand-line {
    animation: expand-line 0.8s ease-out forwards;
  }

  .animation-delay-200 {
    animation-delay: 200ms;
  }

  .animation-delay-300 {
    animation-delay: 300ms;
  }

  .animation-delay-400 {
    animation-delay: 400ms;
  }

  .animation-delay-500 {
    animation-delay: 500ms;
  }

  /* Background Elements */
  .particles-container {
    position: absolute;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
  }

  .particle {
    position: absolute;
    background: linear-gradient(135deg, rgba(168, 85, 247, 0.6), rgba(139, 92, 246, 0.3));
    border-radius: 50%;
    animation: float-particle 15s ease-in-out infinite;
    box-shadow: 0 0 20px rgba(168, 85, 247, 0.3);
  }

  .particle-1 {
    width: 4px;
    height: 4px;
    left: 10%;
    top: 20%;
    animation-delay: 0s;
    animation-duration: 12s;
  }

  .particle-2 {
    width: 6px;
    height: 6px;
    left: 80%;
    top: 60%;
    animation-delay: 2s;
    animation-duration: 14s;
  }

  .particle-3 {
    width: 3px;
    height: 3px;
    left: 60%;
    top: 30%;
    animation-delay: 4s;
    animation-duration: 16s;
  }

  .particle-4 {
    width: 5px;
    height: 5px;
    left: 30%;
    top: 70%;
    animation-delay: 1s;
    animation-duration: 13s;
  }

  .particle-5 {
    width: 4px;
    height: 4px;
    left: 90%;
    top: 40%;
    animation-delay: 3s;
    animation-duration: 15s;
  }

  .particle-6 {
    width: 7px;
    height: 7px;
    left: 20%;
    top: 50%;
    animation-delay: 5s;
    animation-duration: 17s;
  }

  .particle-7 {
    width: 3px;
    height: 3px;
    left: 70%;
    top: 80%;
    animation-delay: 2.5s;
    animation-duration: 11s;
  }

  .particle-8 {
    width: 5px;
    height: 5px;
    left: 45%;
    top: 15%;
    animation-delay: 4.5s;
    animation-duration: 14s;
  }

  .lines-container {
    position: absolute;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
  }

  .line {
    position: absolute;
    width: 200%;
    height: 1px;
    background: linear-gradient(90deg, 
      transparent, 
      rgba(168, 85, 247, 0.4) 20%, 
      rgba(168, 85, 247, 0.8) 50%, 
      rgba(168, 85, 247, 0.4) 80%, 
      transparent
    );
    animation: draw-line 12s linear infinite;
  }

  .line-1 {
    top: 20%;
    animation-delay: 0s;
  }

  .line-2 {
    top: 50%;
    animation-delay: 4s;
    animation-duration: 15s;
  }

  .line-3 {
    top: 75%;
    animation-delay: 8s;
    animation-duration: 18s;
  }

  .rings-container {
    position: absolute;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
  }

  .ring {
    position: absolute;
    border: 2px solid rgba(168, 85, 247, 0.3);
    border-radius: 50%;
    animation: pulse-ring 4s ease-out infinite;
  }

  .ring-1 {
    width: 100px;
    height: 100px;
    top: 30%;
    left: 20%;
    animation-delay: 0s;
  }

  .ring-2 {
    width: 150px;
    height: 150px;
    top: 60%;
    right: 25%;
    animation-delay: 1.5s;
  }

  .ring-3 {
    width: 80px;
    height: 80px;
    bottom: 20%;
    left: 50%;
    animation-delay: 3s;
  }

  /* Background Patterns */
  .bg-grid-pattern {
    background-image: 
      linear-gradient(rgba(139, 92, 246, 0.1) 1.5px, transparent 1.5px),
      linear-gradient(90deg, rgba(139, 92, 246, 0.1) 1.5px, transparent 1.5px);
    background-size: 50px 50px;
  }

  .bg-radial-gradient {
    background: radial-gradient(circle at 50% 50%, transparent 0%, rgba(0, 0, 0, 0.4) 100%);
  }

  /* Custom Prose Styling */
  .prose-custom :global(h1),
  .prose-custom :global(h2),
  .prose-custom :global(h3),
  .prose-custom :global(h4) {
    color: #ffffff;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .prose-custom :global(h2) {
    font-size: 1.875rem;
    background: linear-gradient(to right, #c084fc, #a78bfa);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .prose-custom :global(h3) {
    font-size: 1.5rem;
    color: #e9d5ff;
  }

  .prose-custom :global(p) {
    margin-bottom: 1.5rem;
    line-height: 1.8;
  }

  .prose-custom :global(ul),
  .prose-custom :global(ol) {
    margin: 1.5rem 0;
    padding-left: 2rem;
  }

  .prose-custom :global(li) {
    margin-bottom: 0.75rem;
    line-height: 1.7;
  }

  .prose-custom :global(strong) {
    color: #f3e8ff;
    font-weight: 600;
  }

  .prose-custom :global(a) {
    color: #c084fc;
    text-decoration: underline;
    transition: color 0.3s ease;
  }

  .prose-custom :global(a:hover) {
    color: #e9d5ff;
  }

  .prose-custom :global(code) {
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid rgba(139, 92, 246, 0.2);
    border-radius: 0.375rem;
    padding: 0.125rem 0.375rem;
    font-family: 'Courier New', monospace;
    color: #e9d5ff;
  }

  .prose-custom :global(blockquote) {
    border-left: 4px solid #a78bfa;
    padding-left: 1.5rem;
    font-style: italic;
    color: #d8b4fe;
    margin: 1.5rem 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .ring {
      width: 60px !important;
      height: 60px !important;
    }
  }

  /* Focus states */
  a:focus-visible,
  button:focus-visible {
    outline: 2px solid rgb(168, 85, 247);
    outline-offset: 4px;
    border-radius: 12px;
  }
</style>