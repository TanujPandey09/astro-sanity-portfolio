---
import SectionHeader from "./SectionHeader.astro";

import { useSanityClient, groq } from "astro-sanity";

const skillquery = groq`*[_type == "skillsSection"] {
  ...,
  logoCase[]-> {
    adminstrativetitle,
    Logo {
      ...,
      asset-> {
        ...,
        url,
      }
    }
  }
}[0]`;

const skillsData = await useSanityClient().fetch(skillquery);
const logos = skillsData?.logoCase || [];

// Fallback color palette
const colors = ["#599692", "#626c7d", "#dfe5ec", "#38B2AC", "#61DAFB", "#F7DF1E", "#3178C6", "#F05032", "#47A248"];
---

<section id="skills" class="py-16 md:py-32 relative z-10 bg-[#11172a] overflow-hidden">
  <div class="container mx-auto px-6">
    <SectionHeader 
      title={skillsData?.adminstrativetitle || "Technical"} 
      gradientText={skillsData?.Heading || "Expertise"} 
      subtitle="A comprehensive full-stack skill set centered around modern frameworks, cloud integration, and scalable database architectures."
    />

    <div class="mt-12" data-aos="fade-up">
      <swiper-container 
        class="mySwiper" 
        slides-per-view="1" 
        space-between="20" 
        loop="true" 
        autoplay-delay="2500" 
        autoplay-disable-on-interaction="false"
        breakpoints='{"640": {"slidesPerView": 2, "spaceBetween": 20}, "768": {"slidesPerView": 3, "spaceBetween": 30}, "1024": {"slidesPerView": 4, "spaceBetween": 30}}'
      >
        {
          logos.map((skill: any, index: number) => {
            let rawName = skill?.adminstrativetitle || skill?.Logo?.alt || "Skill";
            const skillName = rawName.replace(/logo\s*section/ig, '').replace(/^[-:\s]+/, '').trim() || "Skill";
            const skillColor = colors[index % colors.length];
            const skillIcon = skill?.Logo?.asset?.url;
            
            return (
              <swiper-slide>
                <div class="group relative p-5 md:p-6 bg-white/[0.02] border border-white/5 rounded-2xl md:rounded-[2rem] hover:-translate-y-1 transition-all duration-500 overflow-hidden hover:shadow-[0_10px_40px_-10px_rgba(0,0,0,0.5)] h-full">
                  <div 
                    class="absolute inset-0 opacity-0 group-hover:opacity-10 transition-opacity duration-500"
                    style={`background: radial-gradient(circle at center, ${skillColor} 0%, transparent 70%)`}
                  ></div>
                  
                  <div class="flex items-center gap-4 relative z-10">
                     <div 
                       class="w-12 h-12 md:w-14 md:h-14 rounded-xl bg-[#000105]/50 border border-white/5 flex items-center justify-center shadow-inner group-hover:scale-110 transition-all duration-500 overflow-hidden"
                       style={`box-shadow: inset 0 0 20px ${skillColor}10; border-color: ${skillColor}30`}
                     >
                        {skillIcon ? (
                          <img src={skillIcon} alt={skillName} class="w-8 h-8 md:w-10 md:h-10 object-contain drop-shadow-[0_0_15px_rgba(255,255,255,0.3)]" />
                        ) : (
                          <span class="text-sm md:text-base font-black" style={`color: ${skillColor}`}>
                            {skillName.charAt(0)}
                          </span>
                        )}
                     </div>
                     
                     <div class="flex-1">
                        <h3 class="text-sm md:text-base font-bold text-white tracking-wide group-hover:tracking-widest transition-all duration-500">
                          {skillName}
                        </h3>
                        <p class="text-[8px] md:text-[9px] text-gray-500 uppercase tracking-[0.2em] mt-1 group-hover:text-gray-300 transition-colors">
                          Professional
                        </p>
                     </div>
                  </div>

                  <div class="absolute bottom-0 left-0 w-full h-[2px] bg-white/5">
                     <div 
                       class="h-full transition-all duration-1000 ease-[cubic-bezier(0.23,1,0.32,1)] w-0 group-hover:w-full opacity-50 group-hover:opacity-100"
                       style={`background-color: ${skillColor}`}
                     ></div>
                  </div>
                </div>
              </swiper-slide>
            );
          })
        }
      </swiper-container>
    </div>
  </div>
</section>

<script>
  import { register } from 'swiper/element/bundle';
  register();
</script>

<style>
  swiper-container {
    width: 100%;
    padding-top: 1rem;
    padding-bottom: 2rem;
  }
</style>
