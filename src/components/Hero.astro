---
---

<section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden">
  <div class="container mx-auto px-6 relative z-20">
    <div class="max-w-6xl mx-auto">
      
      <!-- Visual Accent -->
      <div class="mb-12 flex items-center gap-4" data-aos="fade-down">
         <div class="w-16 h-[2px] bg-[#599692]"></div>
         <span class="text-[10px] font-black uppercase tracking-[0.6em] text-white/40">Digital Architect & Full-Stack Engineer</span>
      </div>

      <div class="relative mb-12" data-aos="zoom-out">
        <h1 class="hero-title font-black text-white leading-[0.85] tracking-tighter uppercase relative z-10">
          Crafting <br/>
          <span class="text-gradient">Immersive</span> <br/>
          Solutions.
        </h1>
        
        <!-- Abstract Decoration -->
        <div class="absolute -top-10 -right-20 w-64 h-64 bg-[#599692]/5 rounded-full blur-3xl -z-10 animate-pulse"></div>
      </div>

      <div class="grid md:grid-cols-12 gap-12 items-end">
        <div class="md:col-span-7" data-aos="fade-right" data-aos-delay="200">
          <p class="text-xl md:text-2xl text-[#94a3b8] leading-relaxed italic mb-12 max-w-2xl font-medium">
            "Bridging the gap between sophisticated aesthetics and high-performance engineering. I build digital ecosystems that resonate."
          </p>
          
          <div class="flex flex-wrap gap-8 items-center">
            <button 
              id="resume-btn"
              class="group relative px-12 py-6 bg-white text-black font-black uppercase text-[10px] tracking-[0.4em] overflow-hidden rounded-full transition-all duration-500 hover:tracking-[0.6em]"
            >
               <span class="relative z-10">Download Intel</span>
               <div class="magnetic-glow absolute inset-0 bg-[#599692] translate-y-[100%] group-hover:translate-y-0 transition-transform duration-500 -z-0"></div>
            </button>

            <a href="#contact" class="text-white font-black uppercase text-[10px] tracking-[0.4em] border-b border-white/20 pb-2 hover:border-[#599692] hover:text-[#599692] transition-all">
              Initiate Project
            </a>
          </div>
        </div>

        <div class="md:col-span-5 flex justify-end" data-aos="fade-left" data-aos-delay="400">
           <div class="relative group">
              <div class="absolute -inset-4 bg-gradient-to-tr from-[#599692] to-[#626c7d] rounded-full opacity-20 blur-2xl group-hover:opacity-40 transition-opacity duration-700"></div>
              <div class="w-48 h-48 md:w-64 md:h-64 rounded-full border border-white/10 p-2 relative z-10 bg-[#11172a]">
                 <img 
                   src="/img/profile.jpg" 
                   alt="Tanuj Pandey" 
                   class="w-full h-full object-cover rounded-full grayscale hover:grayscale-0 transition-all duration-1000"
                 />
              </div>
           </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-title {
    font-size: clamp(2.5rem, 10vw, 7rem);
    perspective: 1000px;
  }

  .text-gradient {
    background: linear-gradient(135deg, #599692 0%, #626c7d 50%, #dfe5ec 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 200% auto;
    animation: gradient-flow 5s linear infinite;
  }

  @keyframes gradient-flow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
</style>

<script>
  import gsap from 'gsap';

  const initHero = () => {
    // Magnetic Button Effect
    const btn = document.querySelector('#resume-btn');
    if (btn) {
      btn.addEventListener('mousemove', (e: any) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        
        gsap.to(btn, {
          x: x * 0.3,
          y: y * 0.3,
          duration: 0.5,
          ease: "power2.out"
        });
      });

      btn.addEventListener('mouseleave', () => {
        gsap.to(btn, {
          x: 0,
          y: 0,
          duration: 0.5,
          ease: "elastic.out(1, 0.3)"
        });
      });

      btn.addEventListener('click', () => {
        const link = document.createElement("a");
        link.href = "/Resume.pdf";
        link.target = "_blank";
        link.download = "resume.pdf";
        link.click();
      });
    }

    // GSAP Reveal
    const tl = gsap.timeline();
    tl.from('.hero-title span', {
      y: 100,
      opacity: 0,
      duration: 1.2,
      stagger: 0.2,
      ease: "power4.out"
    });
  };

  initHero();
</script>
