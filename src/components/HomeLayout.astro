const skillsData = [
  { name: "React.js", level: 95 },
  { name: "Next.js", level: 90 },
  { name: "TypeScript", level: 85 },
  { name: "JavaScript", level: 95 },
  { name: "Tailwind CSS", level: 90 },
  { name: "Node.js", level: 80 },
  { name: "MongoDB", level: 75 },
  { name: "Replit", level: 75 },
  { name: "Git", level: 90 },
];

const achievements = [
  { number: "10+", label: "Projects Completed" },
  { number: "3+", label: "Years Experience" },
  { number: "20%", label: "Performance Boost" },
  { number: "90%", label: "Client Satisfaction" },
];
---

<section class="relative min-h-screen overflow-hidden  font-Roboto">
  <!-- Premium Animated Background -->
  <div class="fixed inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-br from-slate-950 via-purple-950 to-slate-900 animate-gradient-shift"></div>
    
    <div class="absolute inset-0 opacity-60">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-purple-500/30 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
      <div class="absolute top-0 right-1/4 w-96 h-96 bg-violet-500/30 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
      <div class="absolute bottom-0 left-1/3 w-96 h-96 bg-indigo-500/30 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-4000"></div>
    </div>
    
    <!-- Floating particles -->
    <div class="particles-container">
      <div class="particle particle-1"></div>
      <div class="particle particle-2"></div>
      <div class="particle particle-3"></div>
      <div class="particle particle-4"></div>
      <div class="particle particle-5"></div>
      <div class="particle particle-6"></div>
      <div class="particle particle-7"></div>
      <div class="particle particle-8"></div>
    </div>
    
    <!-- Animated lines -->
    <div class="lines-container">
      <div class="line line-1"></div>
      <div class="line line-2"></div>
      <div class="line line-3"></div>
    </div>
    
    <div class="absolute inset-0 bg-grid-pattern opacity-[0.03] animate-grid-float"></div>
    
    <!-- Pulsing rings -->
    <div class="rings-container">
      <div class="ring ring-1"></div>
      <div class="ring ring-2"></div>
      <div class="ring ring-3"></div>
    </div>
    
    <div class="absolute inset-0 bg-radial-gradient"></div>
  </div>

  <div class="container mx-auto px-4 md:px-8 lg:px-12 mt-5 relative z-10">
    <!-- Hero Section -->
    <div class="min-h-screen flex items-center justify-center py-20">
      <div class="text-center max-w-4xl animate-fade-in-up">
        <!-- Profile Image -->
        <div class="profile-image-wrapper mb-8">
          <div class="profile-ring"></div>
          <img
            src="img/profile.jpg"
            alt="Tanuj Pandey"
            class="profile-image"
          />
        </div>

        <h1 class="text-5xl md:text-7xl font-black text-white mb-6 leading-tight">
          Hi, I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 via-violet-400 to-purple-600 animate-gradient-x">Tanuj Pandey</span>
        </h1>

        <p class="text-xl md:text-2xl text-gray-300 mb-4">
          A Result-Oriented <span class="text-purple-400 font-semibold typing-text">Web Developer</span>
        </p>

        <p class="text-gray-400 text-lg mb-12 max-w-2xl mx-auto leading-relaxed">
          Building and managing Websites and Web Applications that lead to the success of the overall product
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
          <button
            type="button"
            class="btn-primary group"
            onclick="downloadResume()"
          >
            <span class="relative z-10 flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Get Resume
            </span>
            <div class="btn-glow"></div>
          </button>

          <a href="#contact" class="btn-secondary group">
            <span class="relative z-10">Let's Talk</span>
          </a>
        </div>

        <!-- Social Links -->
        <div class="flex gap-4 justify-center">
          <a href="https://github.com/TanujPandey09" target="_blank" class="social-icon group">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/tanujdev/" target="_blank" class="social-icon group">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="https://x.com/home" target="_blank" class="social-icon group">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Achievement Stats -->
    <div class="py-20 animate-fade-in">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        {achievements.map((achievement, index) => (
          <div class={`achievement-card animate-scale-in`} style={`animation-delay: ${index * 100}ms`}>
            <div class="text-4xl md:text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-violet-400 mb-2 counter" data-target={achievement.number}>
              {achievement.number}
            </div>
            <div class="text-gray-400 text-sm md:text-base font-medium">{achievement.label}</div>
          </div>
        ))}
      </div>
    </div>

    <!-- Skills Section -->
    <div class="py-20 animate-fade-in">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-white mb-4">
          Technical <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-violet-400">Skills</span>
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-purple-500 to-violet-500 mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {skillsData.map((skill, index) => (
          <div class="skill-card animate-slide-up" style={`animation-delay: ${index * 50}ms`}>
            <div class="flex justify-between items-center mb-3">
              <span class="text-white font-semibold">{skill.name}</span>
              <span class="text-purple-400 font-bold">{skill.level}%</span>
            </div>
            <div class="skill-bar">
              <div class="skill-progress" style={`--skill-width: ${skill.level}%`}></div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Experience Section -->
    <div class="py-20 animate-fade-in">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-white mb-4">
          Professional <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-violet-400">Experience</span>
        </h2>
        <div class="w-24 h-1 bg-gradient-to-r from-purple-500 to-violet-500 mx-auto rounded-full"></div>
      </div>

      <div class="max-w-4xl mx-auto space-y-6">
        {experienceData.map((exp, index) => (
          <div class="experience-card animate-slide-up" style={`animation-delay: ${index * 100}ms`}>
            <div class="flex items-start gap-4 mb-4">
              <div class="company-logo">
                <img src={exp.logo} alt={exp.company} class="w-16 h-16 object-contain rounded-xl" />
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-bold text-white mb-1">{exp.role}</h3>
                <p class="text-purple-400 font-semibold mb-1">{exp.company}</p>
                <p class="text-gray-400 text-sm">{exp.duration} • {exp.type}</p>
              </div>
              <button class="expand-btn" onclick={`toggleExperience(${index})`}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="transition-transform duration-300">
                  <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
            </div>

            <div class="experience-content" id={`content-${index}`}>
              <p class="text-gray-300 mb-4 leading-relaxed">{exp.description}</p>
              <div class="flex flex-wrap gap-2">
                {exp.technologies.map((tech) => (
                  <span class={`tech-badge ${tech.color}`}>{tech.name}</span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Projects Section -->
    <div class="py-20 animate-fade-in">
      <div class="flex justify-between items-center mb-12">
        <h2 class="text-4xl md:text-5xl font-black text-white">
          My <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-violet-400">Works</span>
        </h2>
        <a href="/projects" class="view-all-link group">
          <span>View All</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="group-hover:translate-x-1 transition-transform">
            <path d="M5 12h14m-7-7l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <ProjectSlider projectData={projectData} client:only />
    </div>

    <!-- Blogs Section -->
    <div class="py-20 animate-fade-in">
      <div class="flex justify-between items-center mb-12">
        <h2 class="text-4xl md:text-5xl font-black text-white">
          Latest <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-violet-400">Blogs</span>
        </h2>
        <a href="/blogs" class="view-all-link group">
          <span>View All</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="group-hover:translate-x-1 transition-transform">
            <path d="M5 12h14m-7-7l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <BlogSlider blogData={blogData} client:only />
    </div>

    <!-- Contact Section -->
    <div class="py-20" id="contact">
      <div class="text-center mb-16">
        <h2 class="text-4xl md:text-5xl font-black text-white mb-4">
          Let's Work <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-violet-400">Together</span>
        </h2>
        <p class="text-gray-300 text-lg max-w-2xl mx-auto">
          Have a project in mind? Let's discuss how we can bring your ideas to life
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-6xl mx-auto">
        <!-- Contact Info -->
        <div class="contact-info-card space-y-6">
          <h3 class="text-2xl font-bold text-white mb-6">Get In Touch</h3>
          
          <a href="mailto:tanujp09@gmail.com" class="contact-info-item group">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Email</p>
              <p class="text-white font-semibold group-hover:text-purple-400 transition-colors">tanujp09@gmail.com</p>
            </div>
          </a>

          <div class="contact-info-item">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">Location</p>
              <p class="text-white font-semibold">Delhi, India</p>
            </div>
          </div>

          <a href="https://www.linkedin.com/in/tanujdev/" target="_blank" class="contact-info-item group">
            <div class="contact-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm text-gray-400">LinkedIn</p>
              <p class="text-white font-semibold group-hover:text-purple-400 transition-colors">/tanujdev</p>
            </div>
          </a>

          <div class="flex gap-4 pt-4">
            <a href="https://github.com/TanujPandey09" target="_blank" class="social-link-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </a>
            <a href="https://x.com/home" target="_blank" class="social-link-icon">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
              </svg>
            </a>
          </div>
        </div>

        <!-- Contact Form -->
        <div class="contact-form-card">
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-semibold mb-2 text-gray-300">Name *</label>
              <input type="text" id="name" required class="form-input" placeholder="Your name" />
            </div>

            <div>
              <label class="block text-sm font-semibold mb-2 text-gray-300">Email *</label>
              <input type="email" id="email" required class="form-input" placeholder="your.email@example.com" />
            </div>

            <div>
              <label class="block text-sm font-semibold mb-2 text-gray-300">Subject *</label>
              <input type="text" id="subject" required class="form-input" placeholder="Project inquiry" />
            </div>

            <div>
              <label class="block text-sm font-semibold mb-2 text-gray-300">Message *</label>
              <textarea id="message" required rows="5" class="form-input resize-none" placeholder="Tell me about your project..."></textarea>
