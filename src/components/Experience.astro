---

<section id="experience" class="relative z-10 bg-[#11172a]">
  <div class="experience-pin-wrapper py-32">
    <div class="container mx-auto px-6">
      <div class="grid lg:grid-cols-12 gap-16 items-start">
        
        {/* Left Side: Fixed Content */}
        <div class="lg:col-span-5 lg:sticky lg:top-32 h-fit" data-aos="fade-right">
           <div class="space-y-8">
              <div class="flex items-center gap-3">
                 <div class="h-[1px] w-12 bg-[#599692]"></div>
                 <span class="text-[10px] font-black uppercase tracking-[0.5em] text-[#599692]">Curriculum Vitae</span>
              </div>
              <h2 class="text-white font-black leading-none uppercase tracking-tighter exp-title">
                Professional <br/> <span class="text-gradient">Experience</span>
              </h2>
              <p class="text-gray-400 italic max-w-md exp-subtitle">
                "Building secure, reliable, and performant web applications through a solid track record of product engineering and technical leadership."
              </p>
              
              <div class="hidden lg:block pt-12 space-y-6">
                 {experienceData.map((exp, i) => (
                    <div class="flex items-center gap-4 group cursor-pointer progress-step" data-index={i}>
                       <span class="text-[10px] font-black text-white/20 group-hover:text-white transition-colors">0{i + 1}</span>
                       <div class="flex-1 h-[1px] bg-white/5 relative overflow-hidden">
                          <div class="progress-bar absolute left-0 top-0 bottom-0 bg-[#599692] w-0 transition-all duration-300"></div>
                       </div>
                       <span class="text-[10px] font-black text-white/20 group-hover:text-[#599692] transition-colors">{exp.company}</span>
                    </div>
                 ))}
              </div>
           </div>
        </div>

        {/* Right Side: Scrollable Content */}
        <div class="lg:col-span-7 space-y-16 md:space-y-32">
           {experienceData.map((exp, index) => (
              <div class="experience-card group relative" data-index={index}>
                 <div class="relative z-10 space-y-8">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-white/5 pb-8">
                       <div class="flex items-center gap-4 md:gap-6">
                          <div class="w-12 h-12 md:w-16 md:h-16 rounded-xl md:rounded-2xl bg-white/5 p-2 md:p-3 border border-white/10 group-hover:border-[#599692] transition-all duration-500 overflow-hidden shrink-0">
                             <img src={exp.logo} alt={exp.company} class="w-full h-full object-contain" />
                          </div>
                          <div>
                             <span class="text-[8px] md:text-[10px] font-black uppercase tracking-[0.3em] text-[#599692] block mb-1">{exp.duration}</span>
                             <h3 class="text-white uppercase tracking-tighter leading-tight group-hover:text-gradient transition-all role-title line-clamp-2 md:line-clamp-none">{exp.role}</h3>
                          </div>
                       </div>
                       <div class="flex items-center md:flex-col gap-4 md:gap-1 pl-16 md:pl-0">
                          <a href={exp.companyUrl} target="_blank" class="text-white font-black uppercase tracking-[0.2em] text-[10px] md:text-xs hover:text-[#599692] transition-colors">{exp.company}</a>
                          <span class="px-3 py-1 rounded-full bg-[#626c7d]/10 text-[#626c7d] text-[8px] font-black uppercase tracking-widest">{exp.type}</span>
                       </div>
                    </div>

                    <div class="glass-card p-6 md:p-10 relative overflow-hidden group/desc hover:border-[#599692]/30 transition-colors duration-500 hover:shadow-[0_0_30px_rgba(89,150,146,0.1)]">
                       <div class="absolute -top-12 -right-12 w-24 h-24 bg-[#599692]/5 blur-[60px] -z-10 group-hover/desc:bg-[#599692]/20 transition-all duration-700"></div>
                       <p class="text-gray-400 leading-relaxed italic exp-desc group-hover/desc:text-gray-300 transition-colors duration-500">
                         "{exp.description}"
                       </p>
                    </div>

                    <div class="flex flex-wrap gap-2 md:gap-3">
                       {exp.technologies.map(tech => (
                          <div class="relative group/tech">
                             <span 
                               class="px-3 py-1.5 md:px-4 md:py-2 rounded-lg md:rounded-xl bg-white/5 border border-white/10 text-[8px] md:text-[10px] font-black uppercase text-white/50 hover:text-white hover:-translate-y-1 hover:shadow-lg transition-all block whitespace-nowrap duration-300"
                               style={`border-left: 2px solid ${tech.color}`}
                             >
                                {tech.name}
                             </span>
                          </div>
                       ))}
                    </div>
                 </div>
                 <div class="absolute -inset-4 md:-inset-8 bg-gradient-to-br from-[#599692]/2 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-700 -z-0 rounded-[2rem] md:rounded-[3rem]"></div>
              </div>
           ))}
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .exp-title {
    font-size: clamp(var(--h1-mobile), 8vw, var(--h1-desktop));
  }
  .exp-subtitle {
     font-size: clamp(var(--p-mobile), 1.5vw, var(--p-desktop));
  }
  .role-title {
     font-size: clamp(var(--h3-mobile), 3vw, var(--h3-desktop));
  }
  .exp-desc {
     font-size: var(--p-mobile);
  }
  @media (min-width: 1024px) {
    .exp-desc {
       font-size: var(--p-desktop);
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const initExperienceScroll = () => {
    const cards = gsap.utils.toArray('.experience-card');
    const bars = gsap.utils.toArray('.progress-bar');
    const steps = gsap.utils.toArray('.progress-step');

    cards.forEach((card: any, i) => {
      ScrollTrigger.create({
        trigger: card,
        start: "top 60%",
        end: "bottom 40%",
        onEnter: () => {
          gsap.to(bars[i] as any, { width: '100%', duration: 0.5 });
          gsap.to(steps[i] as any, { opacity: 1, scale: 1.05, duration: 0.3 });
        },
        onLeaveBack: () => {
          gsap.to(bars[i] as any, { width: '0%', duration: 0.5 });
          gsap.to(steps[i] as any, { opacity: 0.5, scale: 1, duration: 0.3 });
        }
      });

      gsap.from(card, {
        opacity: 0,
        y: 100,
        duration: 1.2,
        ease: "expo.out",
        scrollTrigger: {
          trigger: card,
          start: "top 90%",
        }
      });
    });
  };

  initExperienceScroll();
</script>
